    def _create_jump_miss_case(self):
        """创建更明显的KMP跳转漏检案例"""
        # 更明显的例子：多次重复的模式
        text = "AAAABAAAABAAAABAAAAB"
        pattern = "AAAAB"

        self.dna_entry.delete(0, tk.END)
        self.dna_entry.insert(0, text)
        self.pattern_entry.delete(0, tk.END)
        self.pattern_entry.insert(0, pattern)

        explanation = """
        🎯 明显KMP跳转漏检案例：

        文本串：AAAABAAAABAAAABAAAAB
        模式串：AAAAB

        🔍 问题分析：
        1. 模式串"AAAAB"的前缀"AAA"和后缀"AA"有重叠
        2. 当在位置4（字符'B'）失配时，KMP跳转到next[3]=2
        3. 但可能漏掉位置5开始的匹配

        📊 匹配位置：
        - 位置0: AAAAB ✓
        - 位置5: AAAAB ✓
        - 位置10: AAAAB ✓
        - 位置15: AAAAB ✓

        ⚠️ KMP可能漏掉位置5或10的匹配

        ✅ 生物算法通过队列机制确保捕获所有匹配
        """

        messagebox.showinfo("KMP跳转漏检案例", explanation)
