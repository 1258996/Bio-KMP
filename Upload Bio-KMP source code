    def _update_kmp_match_display(self):
        """更新KMP算法的匹配结果显示"""
        # 清空容器
        for widget in self.kmp_matches_container.winfo_children():
            widget.destroy()

        # 从KMP步骤中提取匹配结果
        kmp_matches = []
        for step in self.trad_steps:
            if step.get('type') == 'found':
                match_pos = step.get('i', 0) - len(self.pattern)
                if 0 <= match_pos < len(self.text):
                    kmp_matches.append(match_pos)

        if not kmp_matches:
            tk.Label(self.kmp_matches_container,
                     text="未找到匹配",
                     font=self.FONTS["body"],
                     fg=self.COLORS["text_secondary"],
                     bg=self.COLORS["bg"]).pack(pady=20)
            self.kmp_match_stats.set("KMP匹配统计：未找到匹配")
            return

        # 去重并排序
        kmp_matches = sorted(list(set(kmp_matches)))

        # 更新统计信息
        total_matches = len(kmp_matches)
        self.kmp_match_stats.set(f"KMP匹配统计：共找到 {total_matches} 个匹配")

        # 显示每个匹配位置
        for idx, position in enumerate(kmp_matches, 1):
            match_card = tk.Frame(self.kmp_matches_container,
                                  bg=self.COLORS["bg_alt"],
                                  relief="flat",
                                  highlightbackground=self.COLORS["border"],
                                  highlightthickness=1)
            match_card.pack(fill="x", pady=(0, 10), padx=5)

            # 匹配编号和位置
            header_frame = tk.Frame(match_card, bg=self.COLORS["bg_alt"])
            header_frame.pack(fill="x", padx=10, pady=(8, 4))

            tk.Label(header_frame,
                     text=f"KMP匹配 #{idx}",
                     font=self.FONTS["body_bold"],
                     fg=self.COLORS["primary"],
                     bg=self.COLORS["bg_alt"]).pack(side="left")

            tk.Label(header_frame,
                     text=f"位置: {position}",
                     font=self.FONTS["body"],
                     fg=self.COLORS["info"],
                     bg=self.COLORS["bg_alt"]).pack(side="right")

            # 匹配上下文
            context_size = 5
            start = max(0, position - context_size)
            end = min(len(self.text), position + len(self.pattern) + context_size)
            context = self.text[start:end]
            match_start = position - start
            match_end = match_start + len(self.pattern)

            context_text = f"{context[:match_start]}[{context[match_start:match_end]}]{context[match_end:]}"
            tk.Label(match_card,
                     text=f"上下文: {context_text}",
                     font=self.FONTS["mono"],
                     fg=self.COLORS["text_primary"],
                     bg=self.COLORS["bg_alt"],
                     wraplength=350,
                     justify="left").pack(anchor="w", padx=10, pady=(0, 8))

            # 显示匹配的子串
            pattern_len = len(self.pattern)
            match_substring = self.text[position:position + pattern_len]
            tk.Label(match_card,
                     text=f"匹配子串: {match_substring}",
                     font=self.FONTS["mono"],
                     fg=self.COLORS["primary"],
                     bg=self.COLORS["bg_alt"],
                     wraplength=350,
                     justify="left").pack(anchor="w", padx=10, pady=(0, 8))

    def _next_trad_step(self):
        """KMP算法下一步（修改版）"""
        if self.trad_steps and self.trad_current_step < len(self.trad_steps) - 1:
            self.trad_current_step += 1
            self._draw_trad_scene(self.trad_current_step)
            self._update_trad_log()
            step = self.trad_steps[self.trad_current_step]
            if step.get('type') == 'found':
                self._update_kmp_match_display()
            return True
        return False

