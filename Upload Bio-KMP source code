    def _export_report_action(self, dialog):
        """执行导出报告操作"""
        try:
            # 获取导出参数
            report_name = self.report_name_var.get()
            report_format = self.export_format_var.get()

            # 保存对话框引用以便后续关闭
            self.export_dialog = dialog

            # 选择保存路径
            from tkinter import filedialog
            import os

            # 根据格式设置默认扩展名
            extensions = {
                "HTML": ".html",
                "PDF": ".pdf",
                "TXT": ".txt"
            }

            default_ext = extensions.get(report_format, ".html")

            # 打开文件保存对话框
            file_path = filedialog.asksaveasfilename(
                defaultextension=default_ext,
                filetypes=[
                    (f"{report_format}文件", f"*{default_ext}"),
                    ("所有文件", "*.*")
                ],
                initialfile=f"{report_name}{default_ext}"
            )

            if not file_path:
                dialog.destroy()
                return

            # 开始导出
            self._perform_export(file_path, report_format, dialog)

        except Exception as e:
            messagebox.showerror("导出错误", f"导出过程中发生错误：\n{str(e)}")
            dialog.destroy()

    def _perform_export(self, file_path, report_format, dialog):
        """执行实际的导出操作"""
        try:
            # 显示导出进度
            progress_dialog = self._show_progress_dialog("正在生成报告...")

            # 收集报告数据
            report_data = self._collect_report_data()

            # 根据格式生成报告
            if report_format == "HTML":
                self._export_html_report(file_path, report_data)
            elif report_format == "PDF":
                self._export_pdf_report(file_path, report_data)
            elif report_format == "TXT":
                self._export_txt_report(file_path, report_data)

            # 关闭进度对话框
            if hasattr(self, 'progress_dialog'):
                self.progress_dialog.destroy()

            # 关闭导出对话框
            dialog.destroy()

            # 显示成功消息
            messagebox.showinfo("导出成功",
                                f"✅ 报告已成功导出！\n\n"
                                f"📁 文件位置：{file_path}\n"
                                f"📊 格式：{report_format}\n\n"
                                f"点击确定打开文件所在目录。")

            # 打开文件所在目录
            import os
            os.startfile(os.path.dirname(file_path))

        except Exception as e:
            # 关闭对话框
            if hasattr(self, 'progress_dialog'):
                self.progress_dialog.destroy()

            dialog.destroy()
            messagebox.showerror("导出错误", f"导出过程中发生错误：\n{str(e)}")

    def _collect_report_data(self):
        """收集所有报告数据"""
        report_data = {
            "timestamp": self._get_current_time(),
            "date": self._get_current_date(),

            # 基本信息
            "dna_sequence": getattr(self, 'text', ''),
            "pattern": getattr(self, 'pattern', ''),
            "sequence_length": len(self.text) if hasattr(self, 'text') and self.text else 0,
            "pattern_length": len(self.pattern) if hasattr(self, 'pattern') and self.pattern else 0,

            # 算法性能数据
            "bf_comparisons": 0,
            "kmp_comparisons": 0,
            "opt_comparisons": 0,
            "bf_matches": 0,
            "kmp_matches": 0,
            "opt_matches": 0,

            # 图表数据（如果需要）
            "charts": {},

            # 详细分析
            "analysis_details": "",
            "recommendations": ""
        }

        # 收集算法性能数据
        if hasattr(self, 'bf_steps') and self.bf_steps:
            last_step = self.bf_steps[-1]
            report_data["bf_comparisons"] = last_step.get('comparison_count', 0)
            report_data["bf_matches"] = last_step.get('match_count', 0)

        if hasattr(self, 'trad_steps') and self.trad_steps:
            kmp_comparisons = sum(1 for step in self.trad_steps
                                  if step.get('type') in ['match', 'mismatch'])
            report_data["kmp_comparisons"] = kmp_comparisons

            kmp_matches = sum(1 for step in self.trad_steps
                              if step.get('type') == 'found')
            report_data["kmp_matches"] = kmp_matches

        if hasattr(self, 'opt_steps') and self.opt_steps:
            opt_comparisons = sum(1 for step in self.opt_steps
                                  if step.get('type') in ['match', 'mismatch'])
            report_data["opt_comparisons"] = opt_comparisons

            opt_matches = sum(1 for step in self.opt_steps
                              if step.get('type') == 'found')
            report_data["opt_matches"] = opt_matches

        # 获取分析报告文本
        if hasattr(self, 'comparison_report'):
            self.comparison_report.config(state='normal')
            report_data["analysis_details"] = self.comparison_report.get(1.0, tk.END)
            self.comparison_report.config(state='disabled')

        # 计算效率提升
        if report_data["bf_comparisons"] > 0:
            report_data["kmp_improvement"] = (
                    (report_data["bf_comparisons"] - report_data["kmp_comparisons"]) /
                    report_data["bf_comparisons"] * 100
            )
            report_data["opt_improvement"] = (
                    (report_data["bf_comparisons"] - report_data["opt_comparisons"]) /
                    report_data["bf_comparisons"] * 100
            )

        return report_data

