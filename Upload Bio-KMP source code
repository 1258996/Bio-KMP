    def _show_completion_message(self, bf_data, kmp_data, opt_data, n, m):
        """显示分析完成消息"""
        metrics = self._calculate_performance_metrics(bf_data, kmp_data, opt_data)

        success_msg = "✅ 算法对比分析生成完成！\n\n"
        success_msg += f"📊 数据规模: n={n}, m={m}\n"
        success_msg += f"🔍 匹配结果: BF={metrics['bf_matches']}, KMP={metrics['kmp_matches']}, OPT={metrics['opt_matches']}\n"
        success_msg += f"⚡ 比较次数: BF={metrics['bf_comparisons']:,}, KMP={metrics['kmp_comparisons']:,}, OPT={metrics['opt_comparisons']:,}\n"

        if metrics['bf_comparisons'] > 0:
            success_msg += f"📈 KMP效率提升: {metrics['kmp_improvement']:.1f}%\n"
            if metrics['opt_vs_kmp_improvement'] > 0:
                success_msg += f"📈 生物算法额外提升: {metrics['opt_vs_kmp_improvement']:.1f}%\n"

        success_msg += "\n📄 您可以：\n"
        success_msg += "1. 查看详细分析报告\n"
        success_msg += "2. 浏览对比图表\n"
        success_msg += "3. 点击'导出报告'生成文档\n"
