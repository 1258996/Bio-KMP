    def _format_queue(self, queue, max_items):
        """格式化队列显示"""
        if not queue:
            return "[]"

        items = queue[:max_items]
        formatted = []
        for item in items:
            if isinstance(item, (int, float)):
                formatted.append(str(int(item)))
            else:
                formatted.append(str(item))

        if len(queue) > max_items:
            return f"[{', '.join(formatted)}...](共{len(queue)}项)"
        else:
            return f"[{', '.join(formatted)}]"

    def _get_opt_found_matches(self, step_index):
        """获取生物算法已找到的匹配位置"""
        found_matches = []
        if hasattr(self, 'opt_steps') and self.opt_steps:
            for step in self.opt_steps[:step_index + 1]:
                if step.get('type') in ['found', 'found_by_verification']:
                    match_pos = step.get('match_position', step.get('i', 0) - len(self.pattern))
                    if 0 <= match_pos < len(self.text):
                        found_matches.append(match_pos)

        return list(set(found_matches))  # 去重

    def _get_exclusive_opt_matches(self):
        """获取生物算法特有而KMP漏检的匹配位置"""
        if not hasattr(self, 'opt_steps') or not hasattr(self, 'trad_steps'):
            return []

        # 获取生物算法所有匹配
        opt_matches = []
        for step in self.opt_steps:
            if step.get('type') in ['found', 'found_by_verification']:
                match_pos = step.get('match_position', step.get('i', 0) - len(self.pattern))
                if 0 <= match_pos < len(self.text):
                    opt_matches.append(match_pos)

        # 获取KMP算法所有匹配
        kmp_matches = []
        for step in self.trad_steps:
            if step.get('type') == 'found':
                match_pos = step.get('i', 0) - len(self.pattern)
                if 0 <= match_pos < len(self.text):
                    kmp_matches.append(match_pos)

        # 找出生物算法特有匹配
        opt_set = set(opt_matches)
        kmp_set = set(kmp_matches)
        exclusive_matches = list(opt_set - kmp_set)

        return exclusive_matches

    def _validate_matches_consistency(self):
        """验证KMP和生物算法匹配结果的一致性"""
        if not hasattr(self, 'trad_steps') or not hasattr(self, 'opt_steps'):
            return "数据未生成"

        # 收集KMP算法匹配位置
        kmp_matches = []
        for step in self.trad_steps:
            if step.get('type') == 'found':
                match_pos = step.get('i', 0) - len(self.pattern)
                if 0 <= match_pos < len(self.text):
                    kmp_matches.append(match_pos)

        # 收集生物算法匹配位置
        opt_matches = []
        for step in self.opt_steps:
            if step.get('type') in ['found', 'found_by_verification']:
                match_pos = step.get('i', 0) - len(self.pattern)
                if 0 <= match_pos < len(self.text):
                    opt_matches.append(match_pos)

        # 排序并去重
        kmp_set = sorted(set(kmp_matches))
        opt_set = sorted(set(opt_matches))

        # 比较结果
        if kmp_set == opt_set:
            return f"✅ 两种算法结果一致：{len(kmp_set)}个匹配位置"
        else:
            result = "❌ 两种算法结果不一致：\n"
            result += f"KMP算法找到：{len(kmp_set)}个 ({kmp_set})\n"
            result += f"生物算法找到：{len(opt_set)}个 ({opt_set})\n"

            # 找出差异
            kmp_only = set(kmp_set) - set(opt_set)
            opt_only = set(opt_set) - set(kmp_set)

            if kmp_only:
                result += f"KMP特有：{sorted(list(kmp_only))}\n"
            if opt_only:
                result += f"生物算法特有：{sorted(list(opt_only))}\n"

            return result
