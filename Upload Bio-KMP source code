            canvas_width = self.space_complexity_canvas.winfo_width() or 800
            if canvas_width < 400:
                canvas_width = 800

            canvas_height = 350

            n = len(self.text) if hasattr(self, 'text') and self.text else 10
            m = len(self.pattern) if hasattr(self, 'pattern') and self.pattern else 5

            # 空间复杂度数据
            algorithms = [
                ("暴力算法", "O(1)", 1, self.COLORS["warning"]),
                ("KMP算法", f"O({m})", m, self.COLORS["primary"]),
                ("生物算法", f"O({m}+{n // 4})", m + n // 4, self.COLORS["accent"])
            ]

            # 找到最大值用于归一化
            max_space = max(space for _, _, space, _ in algorithms)
            if max_space == 0:
                max_space = 1

            axis_padding = 80
            bar_width = 80
            spacing = 50
            start_x = axis_padding + 50

            # 确保有足够的宽度
            total_width_needed = start_x + len(algorithms) * (bar_width + spacing) + 100
            canvas_width = max(canvas_width, total_width_needed)

            # 设置画布宽度
            self.space_complexity_canvas.config(width=canvas_width)

            # 绘制坐标轴
            self.space_complexity_canvas.create_line(axis_padding, canvas_height - axis_padding,
                                                     canvas_width - 20, canvas_height - axis_padding,
                                                     fill=self.COLORS["border"], width=2)
            self.space_complexity_canvas.create_line(axis_padding, axis_padding,
                                                     axis_padding, canvas_height - axis_padding,
                                                     fill=self.COLORS["border"], width=2)

            # 绘制柱状图
            for i, (name, complexity, space, color) in enumerate(algorithms):
                x = start_x + i * (bar_width + spacing)

                # 计算柱子高度
                bar_height = (space / max_space) * (canvas_height - 2 * axis_padding)
                if bar_height < 5:  # 最小高度
                    bar_height = 5

                # 绘制柱子
                y_start = canvas_height - axis_padding - bar_height
                self.space_complexity_canvas.create_rectangle(
                    x, y_start,
                    x + bar_width, canvas_height - axis_padding,
                    fill=color,
                    outline=self.COLORS["border"],
                    width=1
                )

                # 显示数值
                self.space_complexity_canvas.create_text(
                    x + bar_width / 2, y_start - 15,
                    text=f"{space} 单位",
                    font=self.FONTS["body_bold"],
                    fill=color
                )

                # 显示算法名称
                self.space_complexity_canvas.create_text(
                    x + bar_width / 2, canvas_height - axis_padding + 20,
                    text=name,
                    font=self.FONTS["body_bold"],
                    fill=self.COLORS["text_primary"]
                )

                # 显示复杂度
                self.space_complexity_canvas.create_text(
                    x + bar_width / 2, canvas_height - axis_padding + 40,
                    text=complexity,
                    font=self.FONTS["small"],
                    fill=self.COLORS["text_secondary"]
                )

            # Y轴刻度
            for i in range(6):
                y = canvas_height - axis_padding - (i / 5) * (canvas_height - 2 * axis_padding)
                value = int(max_space * i / 5)
                self.space_complexity_canvas.create_text(axis_padding - 10, y,
                                                         text=str(value),
                                                         font=self.FONTS["small"],
                                                         fill=self.COLORS["text_tertiary"],
                                                         anchor="e")

                self.space_complexity_canvas.create_line(axis_padding - 5, y,
                                                         axis_padding + 5, y,
                                                         fill=self.COLORS["border"])

            # 图表标题
            self.space_complexity_canvas.create_text(canvas_width // 2, 25,
                                                     text="空间复杂度对比",
                                                     font=self.FONTS["h4"],
                                                     fill=self.COLORS["text_primary"])

            # X轴标签
            self.space_complexity_canvas.create_text(canvas_width // 2, canvas_height - 10,
                                                     text="算法类型",
                                                     font=self.FONTS["body"],
                                                     fill=self.COLORS["text_primary"])

            # Y轴标签
            self.space_complexity_canvas.create_text(25, canvas_height // 2,
                                                     text="空间\n使用量",
                                                     font=self.FONTS["body"],
                                                     fill=self.COLORS["text_primary"],
                                                     angle=90)

            # 更新空间复杂度详细分析
            self._update_space_complexity_details(n, m)

            # 设置滚动区域
            self.space_complexity_canvas.config(scrollregion=self.space_complexity_canvas.bbox("all"))

        except Exception as e:
            print(f"绘制空间复杂度图表错误: {e}")

