    def _validate_data(self):
        """验证数据完整性"""
        validation_errors = []

        # 检查基本信息
        if not hasattr(self, 'text') or not self.text:
            validation_errors.append("未找到DNA序列数据")
        if not hasattr(self, 'pattern') or not self.pattern:
            validation_errors.append("未找到搜索模式数据")

        # 检查算法数据
        if not hasattr(self, 'bf_steps') or not self.bf_steps:
            validation_errors.append("暴力算法数据未生成")
        if not hasattr(self, 'trad_steps') or not self.trad_steps:
            validation_errors.append("KMP算法数据未生成")
        if not hasattr(self, 'opt_steps') or not self.opt_steps:
            validation_errors.append("生物算法数据未生成")

        # 检查长度一致性
        if hasattr(self, 'text') and hasattr(self, 'pattern'):
            if len(self.pattern) > len(self.text):
                validation_errors.append("模式串长度不能大于DNA序列长度")

        if validation_errors:
            error_msg = "数据验证失败：\n\n" + "\n".join(f"• {error}" for error in validation_errors)
            error_msg += "\n\n请先在其他页面生成完整的算法数据。"
            messagebox.showwarning("数据验证失败", error_msg)
            return False

        return True

    def _collect_bf_data(self):
        """收集暴力算法数据"""
        bf_data = {
            'comparison_count': 0,
            'match_count': 0,
            'time_steps': 0,
            'match_positions': [],
            'step_details': []
        }

        if hasattr(self, 'bf_steps') and self.bf_steps:
            # 最后一步的数据
            last_step = self.bf_steps[-1]
            bf_data['comparison_count'] = last_step.get('comparison_count', 0)
            bf_data['match_count'] = last_step.get('match_count', 0)
            bf_data['time_steps'] = len(self.bf_steps)

            # 收集匹配位置
            for step in self.bf_steps:
                if step.get('type') == 'found':
                    match_pos = step.get('start_i', 0)
                    if 0 <= match_pos < len(self.text):
                        bf_data['match_positions'].append(match_pos)

            # 收集关键步骤
            for step in self.bf_steps[:10]:  # 只收集前10步作为示例
                bf_data['step_details'].append({
                    'step': step.get('step', 0),
                    'type': step.get('type', ''),
                    'i': step.get('i', 0),
                    'j': step.get('j', 0),
                    'action': step.get('action', '')
                })

        return bf_data

    def _collect_kmp_data(self):
        """收集KMP算法数据"""
        kmp_data = {
            'comparison_count': 0,
            'match_count': 0,
            'time_steps': 0,
            'match_positions': [],
            'next_operations': [],
            'step_details': []
        }

        if hasattr(self, 'trad_steps') and self.trad_steps:
            # 计算比较次数和匹配数量
            for step in self.trad_steps:
                if step.get('type') in ['match', 'mismatch']:
                    kmp_data['comparison_count'] += 1
                elif step.get('type') == 'found':
                    kmp_data['match_count'] += 1
                    match_pos = step.get('i', 0) - len(self.pattern)
                    if 0 <= match_pos < len(self.text):
                        kmp_data['match_positions'].append(match_pos)

            kmp_data['time_steps'] = len(self.trad_steps)

            # 收集next数组操作
            for step in self.trad_steps:
                if step.get('next_val') not in (None, 'N/A', -1):
                    kmp_data['next_operations'].append({
                        'j': step.get('j', 0),
                        'next_val': step.get('next_val', 0),
                        'action': step.get('action', '')
                    })

            # 收集关键步骤
            for step in self.trad_steps[:10]:
                kmp_data['step_details'].append({
                    'step': step.get('step', 0),
                    'type': step.get('type', ''),
                    'i': step.get('i', 0),
                    'j': step.get('j', 0),
                    'next_val': step.get('next_val', 'N/A'),
                    'action': step.get('action', '')
                })

        return kmp_data

    def _collect_opt_data(self):
        """收集生物算法数据"""
        opt_data = {
            'comparison_count': 0,
            'match_count': 0,
            'time_steps': 0,
            'match_positions': [],
            'jump_operations': [],
            'queue_stats': {'memory_max': 0, 'candidate_max': 0},
            'step_details': []
        }

        if hasattr(self, 'opt_steps') and self.opt_steps:
            # 计算比较次数和匹配数量
            for step in self.opt_steps:
                if step.get('type') in ['match', 'mismatch']:
                    opt_data['comparison_count'] += 1
                elif step.get('type') == 'found':
                    opt_data['match_count'] += 1
                    match_pos = step.get('i', 0) - len(self.pattern)
                    if 0 <= match_pos < len(self.text):
                        opt_data['match_positions'].append(match_pos)

                # 收集跳转操作
                if step.get('jump_distance', 0) > 0:
                    opt_data['jump_operations'].append({
                        'jump_distance': step.get('jump_distance', 0),
                        'reason': step.get('move_reason', '')
                    })

                # 收集队列统计
                memory_len = len(step.get('memory_queue', []))
                candidate_len = len(step.get('candidate_queue', []))
                opt_data['queue_stats']['memory_max'] = max(opt_data['queue_stats']['memory_max'], memory_len)
                opt_data['queue_stats']['candidate_max'] = max(opt_data['queue_stats']['candidate_max'], candidate_len)

            opt_data['time_steps'] = len(self.opt_steps)

            # 收集关键步骤
            for step in self.opt_steps[:10]:
                opt_data['step_details'].append({
                    'step': step.get('step', 0),
                    'type': step.get('type', ''),
                    'i': step.get('i', 0),
                    'j': step.get('j', 0),
                    'jump_distance': step.get('jump_distance', 0),
                    'memory_len': len(step.get('memory_queue', [])),
                    'candidate_len': len(step.get('candidate_queue', [])),
                    'action': step.get('action', '')
                })

        return opt_data

    def _calculate_performance_metrics(self, bf_data, kmp_data, opt_data):
        """计算性能指标"""
        metrics = {
            'bf_comparisons': bf_data['comparison_count'],
            'kmp_comparisons': kmp_data['comparison_count'],
            'opt_comparisons': opt_data['comparison_count'],
            'bf_matches': bf_data['match_count'],
            'kmp_matches': kmp_data['match_count'],
            'opt_matches': opt_data['match_count'],
            'bf_steps': bf_data['time_steps'],
            'kmp_steps': kmp_data['time_steps'],
            'opt_steps': opt_data['time_steps']
        }

        # 计算效率提升
        if metrics['bf_comparisons'] > 0:
            metrics['kmp_improvement'] = (
                    (metrics['bf_comparisons'] - metrics['kmp_comparisons']) /
                    metrics['bf_comparisons'] * 100
            )
            metrics['opt_improvement'] = (
                    (metrics['bf_comparisons'] - metrics['opt_comparisons']) /
                    metrics['bf_comparisons'] * 100
            )
            metrics['opt_vs_kmp_improvement'] = (
                    (metrics['kmp_comparisons'] - metrics['opt_comparisons']) /
                    max(1, metrics['kmp_comparisons']) * 100
            )
        else:
            metrics['kmp_improvement'] = 0
            metrics['opt_improvement'] = 0
            metrics['opt_vs_kmp_improvement'] = 0

        # 计算时间效率
        if metrics['bf_steps'] > 0:
            metrics['kmp_time_efficiency'] = metrics['bf_steps'] / max(1, metrics['kmp_steps'])
            metrics['opt_time_efficiency'] = metrics['bf_steps'] / max(1, metrics['opt_steps'])

        # 计算匹配一致性
        bf_positions = set(bf_data['match_positions'])
        kmp_positions = set(kmp_data['match_positions'])
        opt_positions = set(opt_data['match_positions'])

        metrics['matches_consistent'] = (bf_positions == kmp_positions == opt_positions)
        metrics['bf_unique_matches'] = len(bf_positions - kmp_positions - opt_positions)
        metrics['kmp_unique_matches'] = len(kmp_positions - bf_positions - opt_positions)
        metrics['opt_unique_matches'] = len(opt_positions - bf_positions - kmp_positions)

        # 计算平均比较次数
        n = len(self.text)
        m = len(self.pattern)
        metrics['avg_comparisons_bf'] = metrics['bf_comparisons'] / max(1, n)
        metrics['avg_comparisons_kmp'] = metrics['kmp_comparisons'] / max(1, n)
        metrics['avg_comparisons_opt'] = metrics['opt_comparisons'] / max(1, n)

        return metrics

