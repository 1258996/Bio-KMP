    def _first_trad_step(self):
        """跳转到第一步"""
        self._pause_trad_animation()
        if self.trad_steps:
            self.trad_current_step = 0
            self._draw_trad_scene(self.trad_current_step)
            self._update_trad_log()

    def _prev_trad_step(self):
        """传统方法上一步"""
        self._pause_trad_animation()
        if self.trad_current_step > 0 and self.trad_steps:
            self.trad_current_step -= 1
            self._draw_trad_scene(self.trad_current_step)
            self._update_trad_log()

    def _play_trad_animation(self):
        """播放传统方法动画"""
        if not self.trad_steps:
            messagebox.showinfo("提示", "请先生成数据！")
            return

        if self.trad_animation_id:
            return

        def animate():
            if self._next_trad_step():
                self.trad_animation_id = self.root.after(self.animation_speed, animate)
            else:
                self.trad_animation_id = None

        self.trad_animation_id = self.root.after(100, animate)

    def _pause_trad_animation(self):
        """暂停传统方法动画"""
        if self.trad_animation_id:
            self.root.after_cancel(self.trad_animation_id)
            self.trad_animation_id = None

    def _replay_trad_animation(self):
        """重播传统方法动画"""
        self._first_trad_step()
        self.root.after(500, self._play_trad_animation)

    def _first_opt_step(self):
        """跳转到第一步"""
        self._pause_opt_animation()
        if self.opt_steps:
            self.opt_current_step = 0
            self._draw_opt_scene(self.opt_current_step)
            self._update_opt_log()

    def _prev_opt_step(self):
        """生物方法上一步"""
        self._pause_opt_animation()
        if self.opt_current_step > 0 and self.opt_steps:
            self.opt_current_step -= 1
            self._draw_opt_scene(self.opt_current_step)
            self._update_opt_log()

    def _next_opt_step(self):
        """生物方法下一步"""
        if self.opt_steps and self.opt_current_step < len(self.opt_steps) - 1:
            self.opt_current_step += 1
            self._draw_opt_scene(self.opt_current_step)
            self._update_opt_log()
            return True
        return False

    def _play_opt_animation(self):
        """播放生物方法动画"""
        if not self.opt_steps:
            messagebox.showinfo("提示", "请先生成数据！")
            return

        if self.opt_animation_id:
            return

        def animate():
            if self._next_opt_step():
                self.opt_animation_id = self.root.after(self.animation_speed, animate)
            else:
                self.opt_animation_id = None

        self.opt_animation_id = self.root.after(100, animate)

    def _pause_opt_animation(self):
        """暂停生物方法动画"""
        if self.opt_animation_id:
            self.root.after_cancel(self.opt_animation_id)
            self.opt_animation_id = None

    def _replay_opt_animation(self):
        """重播生物方法动画"""
        self._first_opt_step()
        self.root.after(500, self._play_opt_animation)



    def _toggle_fullscreen(self, event=None):
        """切换全屏状态"""
        self.is_fullscreen = not self.is_fullscreen
        self.root.attributes('-fullscreen', self.is_fullscreen)
        return "break"

    def _exit_fullscreen(self, event=None):
        """退出全屏"""
        self.is_fullscreen = False
        self.root.attributes('-fullscreen', False)
