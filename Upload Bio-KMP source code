    def _update_bf_animation_speed(self):
        """更新暴力算法动画速度"""
        self.animation_speed = self.bf_speed_var.get()

    def _first_bf_step(self):
        """跳转到第一步"""
        self._pause_bf_animation()
        if self.bf_steps:
            self.bf_current_step = 0
            self._draw_bf_scene(self.bf_current_step)
            self._update_bf_log()

    def _prev_bf_step(self):
        """暴力算法上一步"""
        self._pause_bf_animation()
        if self.bf_current_step > 0 and self.bf_steps:
            self.bf_current_step -= 1
            self._draw_bf_scene(self.bf_current_step)
            self._update_bf_log()

    def _next_bf_step(self):
        """暴力算法下一步"""
        if self.bf_steps and self.bf_current_step < len(self.bf_steps) - 1:
            self.bf_current_step += 1
            self._draw_bf_scene(self.bf_current_step)
            self._update_bf_log()
            # 如果这一步是找到匹配，更新匹配显示
            step = self.bf_steps[self.bf_current_step]
            if step['type'] == 'found':
                self._update_bf_match_display()
            return True
        return False

    def _play_bf_animation(self):
        """播放暴力算法动画"""
        if not self.bf_steps:
            messagebox.showinfo("提示", "请先生成数据！")
            return

        if self.bf_animation_id:
            return

        def animate():
            if self._next_bf_step():
                self.bf_animation_id = self.root.after(self.animation_speed, animate)
            else:
                self.bf_animation_id = None

        self.bf_animation_id = self.root.after(100, animate)

    def _pause_bf_animation(self):
        """暂停暴力算法动画"""
        if self.bf_animation_id:
            self.root.after_cancel(self.bf_animation_id)
            self.bf_animation_id = None

    def _replay_bf_animation(self):
        """重播暴力算法动画"""
        self._first_bf_step()
        self.root.after(500, self._play_bf_animation)

    def _update_bf_log(self):
        """更新暴力算法日志"""
        self.bf_log.delete(1.0, tk.END)
        if not self.bf_steps:
            return

        for i, step in enumerate(self.bf_steps[:self.bf_current_step + 1]):
            log_text = f"步骤 {step['step']}: i={step['i']}(开始于{step['start_i']}), j={step['j']} | {step['action']} | 比较次数:{step['comparison_count']}\n"

            if step['type'] == 'match':
                self.bf_log.insert(tk.END, log_text, 'match')
            elif step['type'] == 'mismatch':
                self.bf_log.insert(tk.END, log_text, 'mismatch')
            elif step['type'] == 'found':
                self.bf_log.insert(tk.END, log_text, 'found')
            elif step['type'] == 'end':
                self.bf_log.insert(tk.END, log_text, 'end')
            else:
                self.bf_log.insert(tk.END, log_text)

        self.bf_log.tag_config('match', foreground=self.COLORS["success"])
        self.bf_log.tag_config('mismatch', foreground=self.COLORS["danger"])
        self.bf_log.tag_config('found', foreground=self.COLORS["warning"])
        self.bf_log.tag_config('end', foreground=self.COLORS["info"])
        self.bf_log.see(tk.END)
