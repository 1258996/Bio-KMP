    def _draw_time_complexity_chart_improved(self):
        """绘制改进的时间复杂度对比图表"""
        # 只调用 _draw_unified_complexity_chart 方法
        try:
            if not hasattr(self, 'text') or not self.text:
                return

            self.time_complexity_canvas.delete("all")

            canvas_width = self.time_complexity_canvas.winfo_width() or 600
            canvas_height = self.time_complexity_canvas.winfo_height() or 400

            n = len(self.text) if hasattr(self, 'text') and self.text else 0
            m = len(self.pattern) if hasattr(self, 'pattern') and self.pattern else 0

            if n == 0 or m == 0:
                # 绘制提示信息
                self.time_complexity_canvas.create_text(
                    canvas_width // 2, canvas_height // 2,
                    text="请先在性能对比页面生成分析数据",
                    font=self.FONTS["h4"],
                    fill=self.COLORS["text_secondary"]
                )
                return

            # 只调用统一图表绘制方法
            self._draw_unified_complexity_chart(canvas_width, canvas_height, n, m)

        except Exception as e:
            print(f"绘制时间复杂度图表错误: {e}")
