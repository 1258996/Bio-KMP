            reason_info = f" | 原因: {step.get('move_reason', '')}"
            log_text = f"步骤 {step['step']}: i={step['i']}, j={step['j']}{next_info} | {step['action']}{reason_info}\n"

            if step['type'] == 'match':
                self.trad_log.insert(tk.END, log_text, 'match')
            elif step['type'] == 'mismatch':
                self.trad_log.insert(tk.END, log_text, 'mismatch')
            elif step['type'] == 'found':
                self.trad_log.insert(tk.END, log_text, 'found')
            else:
                self.trad_log.insert(tk.END, log_text)

        self.trad_log.tag_config('match', foreground=self.COLORS["success"])
        self.trad_log.tag_config('mismatch', foreground=self.COLORS["danger"])
        self.trad_log.tag_config('found', foreground=self.COLORS["primary"])
