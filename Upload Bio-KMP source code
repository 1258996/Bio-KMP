            for i, step in enumerate(self.trad_steps):
                if step.get('type') == 'found':
                    match_times.append(i + 1)
            timeline_data["KMP算法"] = match_times if match_times else [0]

        # 生物算法匹配时间
        if hasattr(self, 'opt_steps') and self.opt_steps:
            match_times = []
            for i, step in enumerate(self.opt_steps):
                if step.get('type') == 'found':
                    match_times.append(i + 1)
            timeline_data["生物算法"] = match_times if match_times else [0]

        # 标准化数据长度
        max_len = max(len(timeline_data["暴力算法"]),
                      len(timeline_data["KMP算法"]),
                      len(timeline_data["生物算法"]))

        for algo in timeline_data:
            if len(timeline_data[algo]) < max_len:
                timeline_data[algo] = timeline_data[algo] + [timeline_data[algo][-1]] * (
                            max_len - len(timeline_data[algo]))

        return timeline_data

    def _adjust_color(self, color, brightness=0):
        """调整颜色亮度"""
        if color.startswith('#'):
            r = int(color[1:3], 16)
            g = int(color[3:5], 16)
            b = int(color[5:7], 16)

            # 调整亮度
            r = max(0, min(255, r + brightness))
            g = max(0, min(255, g + brightness))
            b = max(0, min(255, b + brightness))

            return f'#{r:02x}{g:02x}{b:02x}'
        return color
