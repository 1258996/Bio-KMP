        # 添加上游增强子和下游转录起始
        upstream = ''.join(random.choices('ATCG', k=random.randint(20, 40)))
        downstream = ''.join(random.choices('ATCG', k=random.randint(10, 20)))

        full_sequence = upstream + promoter_seq + downstream

        # 设置DNA序列
        self.dna_entry.delete(0, tk.END)
        self.dna_entry.insert(0, full_sequence)

        # 自动设置模式串
        self.pattern_entry.delete(0, tk.END)
        self.pattern_entry.insert(0, "TATA")

