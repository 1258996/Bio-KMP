    # 在 _generate_bf_steps 方法中查找并修复
    def _generate_bf_steps(self):
        """生成暴力匹配算法的步骤 - 添加比较计数器"""
        self.bf_steps = []
        m = len(self.pattern)
        n = len(self.text)

        i = 0  # 主串指针
        j = 0  # 模式串指针
        step_num = 0
        match_count = 0
        comparison_count = 0  # 比较计数器
        start_i = 0  # 本次匹配的起始位置

        # 清空之前的匹配结果
        self.bf_match_positions = []

        while i <= n:
            step_num += 1

            step = {
                'step': step_num,
                'i': i,
                'j': j,
                'start_i': start_i,
                'type': 'start' if step_num == 1 else 'continue',
                'text_char': self.text[i] if i < n else '',
                'pattern_char': self.pattern[j] if j < m else '',
                'action': '',
                'move_reason': '',
                'match_count': match_count,
                'comparison_count': comparison_count,  # 添加比较计数
                'is_matching': True if j < m and i < n else False
            }

            if j == m:  # 完全匹配
                step['type'] = 'found'
                match_pos = start_i  # 这里是关键修复：定义 match_pos 变量
                step['action'] = f'✅ 找到第{match_count + 1}个匹配，位置: {match_pos}'
                step['move_reason'] = '模式串完全匹配成功！'
                match_count += 1

                # 记录匹配位置
                self.bf_match_positions.append({
                    'index': match_count,
                    'position': match_pos,
                    'context': self._get_match_context(match_pos)
                })

                # 继续从下一个位置开始匹配
                start_i += 1
                i = start_i
                j = 0
                self.bf_steps.append(step)
                continue

            if start_i + m > n:  # 剩余长度不足
                step['type'] = 'end'
                step['action'] = f'匹配结束，共找到{match_count}个匹配'
                step['move_reason'] = f'主串剩余长度不足，无法继续匹配'
                self.bf_steps.append(step)
                break

            if i >= n:  # 主串遍历完成
                step['type'] = 'end'
                step['action'] = f'匹配结束，共找到{match_count}个匹配'
                step['move_reason'] = f'主串遍历完成'
                self.bf_steps.append(step)
                break

            # 字符比较
            comparison_count += 1  # 计数器增加

            if self.text[i] == self.pattern[j]:
                step['type'] = 'match'
                step['action'] = f'字符匹配: text[{i}]="{self.text[i]}" == pattern[{j}]="{self.pattern[j]}"'
                step['move_reason'] = '字符相同，继续比较下一个字符'
                step['comparison_count'] = comparison_count
                i += 1
                j += 1
            else:
                step['type'] = 'mismatch'
                step['action'] = f'字符不匹配: text[{i}]="{self.text[i]}" != pattern[{j}]="{self.pattern[j]}"'
                step['move_reason'] = f'字符不匹配，从位置{start_i + 1}重新开始匹配'
                step['comparison_count'] = comparison_count

                # 暴力算法：回溯到下一个位置重新开始
                start_i += 1
                i = start_i
                j = 0

            self.bf_steps.append(step)

        self.bf_step_info.set(f"步骤: 0/{len(self.bf_steps)}")
        # 更新匹配统计
        self._update_bf_match_display()


    def _get_match_context(self, position, context_size=5):
        """获取匹配位置的上下文"""
        start = max(0, position - context_size)
        end = min(len(self.text), position + len(self.pattern) + context_size)

        context = self.text[start:end]
        # 在匹配位置添加标记
        match_start = position - start
        match_end = match_start + len(self.pattern)

        return f"{context[:match_start]}[{context[match_start:match_end]}]{context[match_end:]}"

    def _update_bf_match_display(self):
        """更新暴力算法的匹配结果显示"""
        # 清空容器
        for widget in self.bf_matches_container.winfo_children():
            widget.destroy()

        if not hasattr(self, 'bf_match_positions') or not self.bf_match_positions:
            tk.Label(self.bf_matches_container,
