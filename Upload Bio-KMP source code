    def _analyze_dna_pattern(self):
        """分析基因序列模式 - 修改版本，添加图表更新"""
        try:
            # 获取输入的DNA序列和模式
            dna_sequence = self.dna_entry.get().strip().upper()
            pattern = self.pattern_entry.get().strip().upper()

            print(f"DEBUG: 获取到DNA序列: {dna_sequence[:20]}...")
            print(f"DEBUG: 获取到模式串: {pattern}")

            if not dna_sequence:
                messagebox.showwarning("警告", "DNA序列不能为空！")
                return

            if not pattern:
                messagebox.showwarning("警告", "搜索模式不能为空！")
                return

            # 验证DNA序列只包含ATCG
            valid_bases = set('ATCG')
            invalid_bases = [base for base in dna_sequence if base not in valid_bases]
            if invalid_bases:
                messagebox.showwarning("警告", f"DNA序列只能包含A、T、C、G四种碱基！\n发现非法字符: {invalid_bases[:10]}")
                return

            # 验证模式串
            if not all(base in valid_bases for base in pattern):
                messagebox.showwarning("警告", "模式串只能包含A、T、C、G四种碱基！")
                return

            if len(pattern) > len(dna_sequence):
                messagebox.showwarning("警告", "模式串长度不能大于DNA序列长度！")
                return

            # 计算GC含量
            gc_count = dna_sequence.count('G') + dna_sequence.count('C')
            gc_content = gc_count / len(dna_sequence) * 100

            print(f"DEBUG: 序列长度={len(dna_sequence)}, 模式长度={len(pattern)}, GC含量={gc_content:.1f}%")

            # 显示DNA信息
            info_text = f"DNA序列长度: {len(dna_sequence)}\n"
            info_text += f"GC含量: {gc_content:.1f}%\n"
            info_text += f"AT含量: {100 - gc_content:.1f}%\n"

            # 检查是否为串联重复模式
            if pattern in ["AGC", "AT", "GAA", "CAG", "GC", "CG"]:
                matches = []
                for i in range(len(dna_sequence) - len(pattern) + 1):
                    if dna_sequence[i:i + len(pattern)] == pattern:
                        matches.append(i)

                info_text += f"模式'{pattern}'出现次数: {len(matches)}\n"

                if matches:
                    # 检查是否是串联重复
                    max_tandem = 1
                    current_tandem = 1
                    for i in range(1, len(matches)):
                        if matches[i] == matches[i - 1] + len(pattern):
                            current_tandem += 1
                            max_tandem = max(max_tandem, current_tandem)
                        else:
                            current_tandem = 1

                    info_text += f"最大串联重复数: {max_tandem}\n"

                    if max_tandem >= 3:
                        info_text += "⚠️ 检测到显著串联重复，可能与遗传疾病相关\n"

            messagebox.showinfo("DNA序列分析", info_text)

            # 调用原有的生成和分析函数
            self.text = dna_sequence
            self.pattern = pattern

            print(f"DEBUG: 设置text={self.text[:20]}..., pattern={self.pattern}")

            # 生成跳转表
            self.next_table = self._build_next_table(self.pattern)
            print(f"DEBUG: 生成next_table: {self.next_table}")

            # 生成步骤
            self._generate_trad_steps()
            print(f"DEBUG: 传统KMP步骤数量: {len(self.trad_steps)}")

            self._generate_opt_steps()
            print(f"DEBUG: 生物算法步骤数量: {len(self.opt_steps)}")

            self._generate_bf_steps()  # 添加暴力算法步骤生成
            print(f"DEBUG: 暴力算法步骤数量: {len(self.bf_steps)}")

            # 绘制next数组
            self._draw_next_table_canvas(self.trad_next_canvas, self.next_table)
            self._draw_next_table_canvas(self.opt_next_canvas, self.next_table)

            # 初始化页面
            self._init_pages()

            # ========== 关键修复：生成性能对比数据并更新图表 ==========
            print("DEBUG: 开始生成性能对比数据...")

            # 收集各算法的比较次数
            bf_comparisons = 0
            kmp_comparisons = 0
            opt_comparisons = 0

            # 暴力算法比较次数（从最后一步获取）
            if hasattr(self, 'bf_steps') and self.bf_steps:
                last_bf_step = self.bf_steps[-1]
                bf_comparisons = last_bf_step.get('comparison_count', 0)
                print(f"DEBUG: 暴力算法比较次数: {bf_comparisons}")

            # KMP算法比较次数（统计match和mismatch步骤）
            if hasattr(self, 'trad_steps') and self.trad_steps:
                kmp_comparisons = sum(1 for step in self.trad_steps if step.get('type') in ['match', 'mismatch'])
                print(f"DEBUG: KMP算法比较次数: {kmp_comparisons}")

            # 生物算法比较次数（统计match和mismatch步骤）
            if hasattr(self, 'opt_steps') and self.opt_steps:
                opt_comparisons = sum(1 for step in self.opt_steps if step.get('type') in ['match', 'mismatch'])
                print(f"DEBUG: 生物算法比较次数: {opt_comparisons}")

            # 更新性能对比页面的统计信息
            if hasattr(self, 'bf_comparison_stats'):
                bf_stats = f"暴力算法比较次数: {bf_comparisons:,}\n"
                bf_stats += f"文本长度: {len(self.text)}\n"
                bf_stats += f"模式长度: {len(self.pattern)}\n"
                bf_stats += f"时间复杂度: O(n×m)"
                self.bf_comparison_stats.set(bf_stats)

            if hasattr(self, 'kmp_comparison_stats'):
                kmp_stats = f"KMP算法比较次数: {kmp_comparisons:,}\n"
                kmp_stats += f"文本长度: {len(self.text)}\n"
                kmp_stats += f"模式长度: {len(self.pattern)}\n"
                kmp_stats += f"时间复杂度: O(n+m)"
                self.kmp_comparison_stats.set(kmp_stats)

            if hasattr(self, 'opt_comparison_stats'):
                opt_stats = f"生物算法比较次数: {opt_comparisons:,}\n"
                opt_stats += f"文本长度: {len(self.text)}\n"
                opt_stats += f"模式长度: {len(self.pattern)}\n"
                opt_stats += f"时间复杂度: O(n+m)"
                self.opt_comparison_stats.set(opt_stats)

            # ========== 关键：更新比较次数图表 ==========
            print(f"DEBUG: 准备更新图表 - 暴力:{bf_comparisons}, KMP:{kmp_comparisons}, 生物:{opt_comparisons}")

            # 延迟一点时间，确保画布已就绪
            self.root.after(500,
                            lambda: self._update_comparison_charts(bf_comparisons, kmp_comparisons, opt_comparisons))

            # 切换到暴力算法页面（第二页）
            self.main_notebook.select(1)  # 索引1是第二个页面（暴力算法）

            # 自动播放暴力算法动画
            self.root.after(1000, self._play_bf_animation)

            # 显示成功消息，提示用户可以查看对比分析
            messagebox.showinfo("成功",
                                f"数据分析完成！\n\n"
                                f"DNA序列长度: {len(dna_sequence)}\n"
                                f"模式串长度: {len(pattern)}\n\n"
                                f"您可以：\n"
                                f"1. 查看暴力算法动画\n"
                                f"2. 查看KMP算法动画\n"
                                f"3. 查看生物算法动画\n"
                                f"4. 在'算法对比'页面查看性能图表")

        except Exception as e:
            error_msg = f"分析DNA序列失败：{str(e)}\n\n详细错误信息："
            import traceback
            error_msg += f"\n{traceback.format_exc()}"
            messagebox.showerror("错误", error_msg)
            print(f"ERROR: {error_msg}")
