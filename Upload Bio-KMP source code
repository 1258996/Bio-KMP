    def _get_char_style(self, position, step, found_matches, exclusive_matches):
        """获取文本串字符的样式"""
        style = {
            "fill": self.COLORS["primary_light"],
            "outline": self.COLORS["primary"],
            "text": self.COLORS["primary_dark"],
            "marks": []
        }

        # 检查是否在已找到的匹配中
        is_in_match = False
        for match_start in found_matches:
            if match_start <= position < match_start + len(self.pattern):
                is_in_match = True
                break

        # 检查是否是生物算法特有匹配
        is_exclusive = position in exclusive_matches

        # 检查是否是候选队列位置
        is_candidate = False
        candidate_q = step.get('candidate_queue', [])
        for item in candidate_q:
            if isinstance(item, (list, tuple)) and len(item) >= 1:
                if item[0] == position:
                    is_candidate = True
                    break

        # 检查是否是记忆队列位置
        is_memory = position in step.get('memory_queue', [])

        # 设置样式
        if is_exclusive:
            style["fill"] = self.COLORS["success"]
            style["outline"] = self.COLORS["success_dark"]
            style["text"] = self.COLORS["bg"]
            style["marks"].append("exclusive")
        elif is_in_match:
            style["fill"] = self.COLORS["success"]
            style["outline"] = self.COLORS["success_dark"]
            style["text"] = self.COLORS["bg"]
            style["marks"].append("match")
        elif position == step['i']:
            style["fill"] = self.COLORS["primary"]
            style["outline"] = self.COLORS["primary_dark"]
            style["text"] = self.COLORS["bg"]
            style["marks"].append("current")
        elif is_candidate:
            style["fill"] = self.COLORS["success_light"]
            style["outline"] = self.COLORS["success"]
            style["text"] = self.COLORS["success_dark"]
            style["marks"].append("candidate")
        elif is_memory:
            style["fill"] = self.COLORS["warning_light"]
            style["outline"] = self.COLORS["warning"]
            style["text"] = self.COLORS["warning_dark"]
            style["marks"].append("memory")

        return style

    def _get_pattern_char_style(self, position, step):
        """获取模式串字符的样式"""
        style = {
            "fill": self.COLORS["secondary_light"],
            "outline": self.COLORS["secondary"],
            "text": self.COLORS["secondary_dark"]
        }

        if position < step['j']:
            # 已匹配的部分
            style["fill"] = self.COLORS["success_light"]
            style["outline"] = self.COLORS["success"]
            style["text"] = self.COLORS["success_dark"]
        elif position == step['j']:
            # 当前正在比较的位置
            if step['type'] == 'mismatch' and step['i'] < len(self.text) and step['j'] < len(self.pattern):
                style["fill"] = self.COLORS["danger"]
                style["outline"] = self.COLORS["danger_dark"]
                style["text"] = self.COLORS["bg"]
            else:
                style["fill"] = self.COLORS["primary"]
                style["outline"] = self.COLORS["primary_dark"]
                style["text"] = self.COLORS["bg"]

        return style

