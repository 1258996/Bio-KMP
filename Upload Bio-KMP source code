    def _update_comparison_charts(self, bf_comparisons, kmp_comparisons, opt_comparisons):
        """更新对比分析图表"""
        try:
            if not hasattr(self, 'comparison_charts_canvas'):
                self._create_comparison_charts()

            # 更新柱状图数据
            algorithms = ['暴力匹配', 'KMP算法', '生物算法']
            values = [bf_comparisons, kmp_comparisons, opt_comparisons]

            # 更新柱状图
            self.bar_ax.clear()
            bars = self.bar_ax.bar(algorithms, values,
                                   color=['#FF6B6B', '#4ECDC4', '#95E1D3'],
                                   edgecolor='white', linewidth=2)
            self.bar_ax.set_title('算法比较次数对比', fontsize=14, fontweight='bold', pad=15)
            self.bar_ax.set_ylabel('比较次数', fontsize=12)
            self.bar_ax.tick_params(axis='x', labelsize=11)
            self.bar_ax.tick_params(axis='y', labelsize=10)

            # 在柱子上显示数值
            for bar, value in zip(bars, values):
                height = bar.get_height()
                self.bar_ax.text(bar.get_x() + bar.get_width() / 2., height + max(values) * 0.02,
                                 f'{value}', ha='center', va='bottom', fontsize=11, fontweight='bold')

            # 设置y轴范围
            self.bar_ax.set_ylim(0, max(values) * 1.2)
            self.bar_ax.grid(True, alpha=0.3, linestyle='--')

            # 更新折线图数据
            if not hasattr(self, 'comparison_history'):
                self.comparison_history = []

            self.comparison_history.append({
                '暴力匹配': bf_comparisons,
                'KMP算法': kmp_comparisons,
                '生物算法': opt_comparisons
            })

            # 只保留最近10次记录
            if len(self.comparison_history) > 10:
                self.comparison_history = self.comparison_history[-10:]

            # 更新折线图
            self.line_ax.clear()
            iterations = list(range(1, len(self.comparison_history) + 1))

            for algo, color in zip(['暴力匹配', 'KMP算法', '生物算法'], ['#FF6B6B', '#4ECDC4', '#95E1D3']):
                values = [record[algo] for record in self.comparison_history]
                self.line_ax.plot(iterations, values, marker='o', linewidth=2.5,
                                  markersize=6, label=algo, color=color)

            self.line_ax.set_title('比较次数变化趋势', fontsize=14, fontweight='bold', pad=15)
            self.line_ax.set_xlabel('测试次数', fontsize=12)
            self.line_ax.set_ylabel('比较次数', fontsize=12)
            self.line_ax.legend(fontsize=10, loc='upper right')
            self.line_ax.grid(True, alpha=0.3, linestyle='--')
            self.line_ax.tick_params(axis='both', labelsize=10)

            # 设置x轴刻度为整数
            if iterations:
                self.line_ax.set_xticks(iterations)

            # 更新饼图
            self.pie_ax.clear()
            total = bf_comparisons + kmp_comparisons + opt_comparisons
            if total > 0:
                sizes = [bf_comparisons, kmp_comparisons, opt_comparisons]
                colors = ['#FF6B6B', '#4ECDC4', '#95E1D3']
                explode = (0.05, 0.05, 0.05)

                wedges, texts, autotexts = self.pie_ax.pie(
                    sizes, explode=explode, colors=colors,
                    autopct=lambda pct: f'{pct:.1f}%\n({int(pct / 100 * total)})',
                    startangle=90, shadow=True
                )

                for autotext in autotexts:
                    autotext.set_color('white')
                    autotext.set_fontsize(10)
                    autotext.set_fontweight('bold')

                self.pie_ax.set_title('比较次数占比', fontsize=14, fontweight='bold', pad=15)
                self.pie_ax.legend(wedges, algorithms, title="算法", loc="center left",
                                   bbox_to_anchor=(1, 0, 0.5, 1), fontsize=10)
            else:
                self.pie_ax.text(0.5, 0.5, '无比较数据', ha='center', va='center',
                                 fontsize=12, fontweight='bold')
                self.pie_ax.set_title('比较次数占比', fontsize=14, fontweight='bold', pad=15)

            # 调整布局并重绘
            self.comparison_charts_canvas.figure.tight_layout()
            self.comparison_charts_canvas.draw()

            # 更新统计信息标签
            if hasattr(self, 'comparison_stats_label'):
                efficiency = f"效率提升: KMP vs 暴力: {bf_comparisons / kmp_comparisons:.1f}x, 生物 vs 暴力: {bf_comparisons / opt_comparisons:.1f}x"
                self.comparison_stats_label.config(
                    text=f"暴力匹配: {bf_comparisons}次 | KMP: {kmp_comparisons}次 | 生物算法: {opt_comparisons}次\n{efficiency}"
                )

            print(f"对比图表已更新：暴力={bf_comparisons}, KMP={kmp_comparisons}, 生物={opt_comparisons}")

        except Exception as e:
            print(f"更新对比图表时出错: {e}")
    def _save_report_data(self, bf_data, kmp_data, opt_data, metrics, n, m):
        """保存报告数据供导出使用"""
        self.report_data = {
            'timestamp': self._get_current_time(),
            'date': self._get_current_date(),
            'report_id': self._generate_report_id(),

            # 基本数据
            'dna_sequence': self.text,
            'pattern': self.pattern,
            'sequence_length': n,
            'pattern_length': m,

            # 性能数据
            'bf_data': bf_data,
            'kmp_data': kmp_data,
            'opt_data': opt_data,

            # 性能指标
            'metrics': metrics,

            # 图表数据
            'has_charts': True,

            # 分析报告文本
            'analysis_text': self.comparison_report.get(1.0, tk.END) if hasattr(self, 'comparison_report') else "",

            # 系统信息
            'system_version': '基因序列模式匹配分析系统 v2.0'
        }

        # 打印调试信息
        print(f"报告数据已保存，ID: {self.report_data['report_id']}")
        print(f"暴力算法比较次数: {metrics['bf_comparisons']}")
        print(f"KMP算法比较次数: {metrics['kmp_comparisons']}")
        print(f"生物算法比较次数: {metrics['opt_comparisons']}")

