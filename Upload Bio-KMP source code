        else:
            self.trad_next_details.set("当前无需查表")

        self.trad_step_info.set(f"步骤: {step_index + 1}/{len(self.trad_steps)}")

        total_chars = max(len(self.text), len(self.pattern) + step['i'] - step['j'])

        canvas_width = self.trad_canvas.winfo_width() or 800
        available_width = canvas_width - 250

        if total_chars * self.SIZES["char_width"] > available_width:
            char_width = max(45, available_width // max(1, total_chars))
        else:
            char_width = self.SIZES["char_width"]

        char_height = self.SIZES["char_height"]

        text_y = self.SIZES["text_start_y"]

        # ========== 关键：计算KMP算法的焦点位置 ==========
        current_i = step['i']

        # 对于KMP算法，焦点在主串指针i
        focus_position = current_i

        # 计算焦点字符的X坐标
        focus_char_x = self.SIZES["text_start_x"] + focus_position * char_width

        # 计算画布应该滚动到的位置
        viewport_width = canvas_width
        target_scroll_x = max(0, focus_char_x - viewport_width / 2)

        self.trad_canvas.create_text(self.SIZES["title_offset_x"], text_y - self.SIZES["text_title_offset_y"],
                                     text="📝 文本串:",
                                     font=self.FONTS["h3"],
                                     fill=self.COLORS["primary"],
                                     anchor="w")

        # 先绘制所有已找到的匹配
        found_matches = []
        for step_match in self.trad_steps[:step_index + 1]:
            if step_match.get('type') == 'found':
                match_start = step_match.get('i', 0) - len(self.pattern)
                if 0 <= match_start < len(self.text):
                    found_matches.append(match_start)

        # 绘制文本串字符
        for i, c in enumerate(self.text):
            char_x = self.SIZES["text_start_x"] + i * char_width

            # 检查当前位置是否在已找到的匹配中
            is_in_match = False
            for match_start in found_matches:
                if match_start <= i < match_start + len(self.pattern):
                    is_in_match = True
                    break

            if is_in_match:
                fill_color = self.COLORS["success"]
                outline_color = self.COLORS["success_dark"]
                text_color = self.COLORS["bg"]
            elif i == step['i']:
                fill_color = self.COLORS["primary"]
                outline_color = self.COLORS["primary_dark"]
                text_color = self.COLORS["bg"]
            else:
                fill_color = self.COLORS["primary_light"]
                outline_color = self.COLORS["primary"]
                text_color = self.COLORS["primary_dark"]

            self.trad_canvas.create_rectangle(
                char_x, text_y,
                char_x + char_width, text_y + char_height,
                fill=fill_color, outline=outline_color, width=2
            )

            self.trad_canvas.create_text(
                char_x + char_width / 2, text_y + char_height / 2,
                text=c, font=self.FONTS["h4"], fill=text_color
            )

            self.trad_canvas.create_text(
                char_x + char_width / 2, text_y + char_height + self.SIZES["index_offset"],
                text=str(i), font=self.FONTS["body"], fill=self.COLORS["text_tertiary"]
            )

        # 绘制主串指针 - 向下调整位置（向下移动10像素）
        if step['i'] < len(self.text):
            i_char_x = self.SIZES["text_start_x"] + step['i'] * char_width + char_width / 2
            i_pointer_y = text_y - 10
            self._draw_pointer_with_label(self.trad_canvas, i_char_x, i_pointer_y,
                                          self.COLORS["primary"], f"i={step['i']}", "", "down")

        pattern_y = text_y + char_height + self.SIZES["vertical_spacing"]
        pattern_start_x = self.SIZES["text_start_x"] + (step['i'] - step['j']) * char_width

        self.trad_canvas.create_text(self.SIZES["title_offset_x"], pattern_y - self.SIZES["pattern_title_offset_y"],
                                     text="🔍 模式串:",
                                     font=self.FONTS["h3"],
                                     fill=self.COLORS["secondary"],
                                     anchor="w")

        # 绘制模式串
        for i, c in enumerate(self.pattern):
            char_x = pattern_start_x + i * char_width

            if i < step['j']:
                fill_color = self.COLORS["success_light"]
                outline_color = self.COLORS["success"]
                text_color = self.COLORS["success_dark"]
            elif i == step['j']:
                if step['type'] == 'mismatch' and step['i'] < len(self.text) and step['j'] < len(self.pattern):
                    fill_color = self.COLORS["danger"]
                    outline_color = self.COLORS["danger_dark"]
                else:
                    fill_color = self.COLORS["primary"]
                    outline_color = self.COLORS["primary_dark"]
                text_color = self.COLORS["bg"]
            else:
                fill_color = self.COLORS["secondary_light"]
                outline_color = self.COLORS["secondary"]
                text_color = self.COLORS["secondary_dark"]

            self.trad_canvas.create_rectangle(
                char_x, pattern_y,
                char_x + char_width, pattern_y + char_height,
                fill=fill_color, outline=outline_color, width=2
            )

            self.trad_canvas.create_text(
                char_x + char_width / 2, pattern_y + char_height / 2,
                text=c, font=self.FONTS["h4"], fill=text_color
            )

            self.trad_canvas.create_text(
                char_x + char_width / 2, pattern_y + char_height + self.SIZES["index_offset"],
                text=str(i), font=self.FONTS["body"], fill=self.COLORS["text_tertiary"]
            )

        if step['j'] < len(self.pattern):
            j_char_x = pattern_start_x + step['j'] * char_width + char_width / 2
            j_pointer_y = pattern_y + char_height + 60
            self._draw_pointer_with_label(self.trad_canvas, j_char_x, j_pointer_y,
                                          self.COLORS["secondary"], f"j={step['j']}", "", "up")

        # 如果有next跳转，绘制跳转箭头
        if step['type'] == 'mismatch' and step.get('next_val', -1) >= 0 and step['j'] > 0:
            old_j = step['j'] - 1
            old_x = pattern_start_x + old_j * char_width + char_width / 2

            if step['j'] > 0:  # 只有当j>0时才绘制跳转
                # 绘制弯曲箭头表示跳转
                self.trad_canvas.create_line(
                    old_x, pattern_y + char_height + 60,
                           (old_x + j_char_x) / 2, pattern_y + char_height + 120,
                    j_char_x, pattern_y + char_height + 60,
                    arrow=tk.LAST,
                    fill=self.COLORS["warning"],
                    width=2,
                    arrowshape=(10, 12, 6),
                    smooth=True
                )

                next_val = step.get('next_val', 0)
                self.trad_canvas.create_text(
                    (old_x + j_char_x) / 2, pattern_y + char_height + 140,
                    text=f"next[{old_j}] = {next_val}",
                    font=self.FONTS["body_bold"],
                    fill=self.COLORS["warning_dark"]
                )

        # ========== 自动滚动画布 ==========
        if hasattr(self, 'scroll_tracking_enabled') and self.scroll_tracking_enabled:
            # 获取当前画布的总宽度
            bbox = self.trad_canvas.bbox("all")
            if bbox:
                canvas_width_total = bbox[2] - bbox[0]
                # 计算滚动比例
                if canvas_width_total > viewport_width:
                    scroll_ratio = target_scroll_x / max(1, canvas_width_total - viewport_width)
                    scroll_ratio = max(0, min(1, scroll_ratio))

                    # 设置滚动位置
                    self.trad_canvas.xview_moveto(scroll_ratio)

        # 在焦点位置添加高亮标记（可选）
        if 0 <= focus_position < len(self.text):
            focus_char_x = self.SIZES["text_start_x"] + focus_position * char_width
            self.trad_canvas.create_rectangle(
                focus_char_x - 2, text_y - 5,
                focus_char_x + char_width + 2, text_y + char_height + 5,
                outline=self.COLORS["primary"],
                width=3,
                dash=(5, 2)
            )

        self.trad_canvas.configure(scrollregion=self.trad_canvas.bbox("all"))



