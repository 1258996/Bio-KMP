    def _build_next_table(self, pattern):
        """构建跳转表"""
        n = len(pattern)
        next_table = [0] * n
        j = 0
        for i in range(1, n):
            while j > 0 and pattern[i] != pattern[j]:
                j = next_table[j - 1]
            if pattern[i] == pattern[j]:
                j += 1
            next_table[i] = j
        return next_table

    def _calculate_verification_window_exact(self, pattern):
        """精确计算验证窗口大小 L"""
        m = len(pattern)

        if m == 0:
            return 1

        # 计算最大重复单元长度
        max_repeat_len = 1

        # 检查模式串中的重复单元
        for unit_len in range(1, m // 2 + 1):
            if m % unit_len == 0:
                unit = pattern[:unit_len]
                repeats = m // unit_len
                if unit * repeats == pattern:
                    max_repeat_len = max(max_repeat_len, unit_len)

        # L = min(m/2, 最大重复单元长度)
        L = min(m // 2, max_repeat_len)

        # 确保至少为1
        return max(1, L)

    def _calculate_min_safe_jump(self, pattern, j, window_size):
        """计算最小安全跳转距离 - 核心算法"""
        # 确保 j > 0
        if j <= 0:
            return 0

        # 确保 window_size 有效
        window_size = min(window_size, j)

        # 尝试找到最小的安全跳转距离
        for k in range(1, window_size + 1):
            # 检查前缀和后缀是否匹配
            prefix = pattern[0:j - k]
            suffix = pattern[k:j]
            if prefix == suffix:
                return k

        # 如果没有找到安全的跳转，使用默认最小跳转
        return 1

    def _check_candidate_positions(self, memory_queue, candidate_queue, current_i, current_j):
        """检查记忆队列中的位置是否可能为新起点"""
        new_candidates = []

        for mem_pos in list(memory_queue):
            # 检查该位置是否可能为新的匹配起点
            if mem_pos + current_j <= len(self.text):
                # 检查是否已匹配部分字符
                matched_len = 0
                for k in range(min(len(self.pattern), len(self.text) - mem_pos)):
                    if self.text[mem_pos + k] == self.pattern[k]:
                        matched_len = k + 1
                    else:
                        break

                # 如果至少匹配2个字符，加入候选队列
                if matched_len >= 2:
                    candidate = {
                        'pos': mem_pos,
                        'matched_len': matched_len,
                        'discovered_at': current_i
                    }

                    # 检查是否已在候选队列中
                    exists = False
                    for cand in candidate_queue:
                        if isinstance(cand, dict) and cand['pos'] == mem_pos:
                            exists = True
                            break

                    if not exists:
                        new_candidates.append(candidate)

        # 添加到候选队列
        for cand in new_candidates:
            candidate_queue.append(cand)

    def _verify_candidate(self, position, matched_len):
        """验证候选位置是否真正匹配"""
        # 检查候选位置的上下文匹配情况
        if position + len(self.pattern) > len(self.text):
            return False

        # 验证已匹配部分
        for i in range(matched_len):
            if self.text[position + i] != self.pattern[i]:
                return False

        # 验证剩余部分
        for i in range(matched_len, len(self.pattern)):
            if self.text[position + i] != self.pattern[i]:
                return False

        return True
    def _calculate_min_safe_jump(self, pattern, j, window_size):
        """计算最小安全跳转距离 - 确保返回有效值"""
        # 确保j大于0
        if j <= 0:
            return 0

        # 确保window_size有效
        window_size = min(window_size, j)

        # 尝试找到最小的安全跳转距离
        for k in range(1, window_size + 1):
            # 检查前缀和后缀是否匹配
            prefix = pattern[0:j - k]
            suffix = pattern[k:j]
            if prefix == suffix:
                return k

        # 如果没有找到，返回j（完全回退）
        return j

