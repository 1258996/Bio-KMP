    def _get_enhanced_pattern_style(self, position, step):
        """获取增强的模式串字符样式"""
        style = {
            "fill": self.COLORS["secondary_light"],
            "outline": self.COLORS["secondary"],
            "text": self.COLORS["secondary_dark"]
        }

        if position < step['j']:
            # 已匹配的部分
            style["fill"] = self.COLORS["success_light"]
            style["outline"] = self.COLORS["success"]
            style["text"] = self.COLORS["success_dark"]

            # 如果当前位置刚好是跳转的起始点
            if step['type'] == 'mismatch' and position == step['j'] - 1:
                style["outline"] = self.COLORS["warning"]
                style["text"] = self.COLORS["warning_dark"]

        elif position == step['j']:
            # 当前正在比较的位置
            if step['type'] == 'mismatch':
                style["fill"] = self.COLORS["danger"]
                style["outline"] = self.COLORS["danger_dark"]
                style["text"] = self.COLORS["bg"]
            else:
                style["fill"] = self.COLORS["primary"]
                style["outline"] = self.COLORS["primary_dark"]
                style["text"] = self.COLORS["bg"]

        return style

    def _draw_enhanced_jump_arrow(self, step, pattern_start_x, char_width, pattern_y, char_height):
        """绘制增强的跳转箭头"""
        old_j = step['j'] + step.get('jump_distance', 0)
        if old_j < len(self.pattern):
            old_x = pattern_start_x + old_j * char_width + char_width / 2
            new_x = pattern_start_x + step['j'] * char_width + char_width / 2

            # 绘制弯曲箭头
            self.opt_canvas.create_line(
                old_x, pattern_y + char_height + 40,
                       (old_x + new_x) / 2, pattern_y + char_height + 80,
                new_x, pattern_y + char_height + 40,
                arrow=tk.LAST,
                fill=self.COLORS["warning"],
                width=3,
                arrowshape=(12, 15, 8),
                smooth=True
            )

            # 绘制跳转说明
            self.opt_canvas.create_text(
                (old_x + new_x) / 2, pattern_y + char_height + 100,
                text=f"安全跳转: {step.get('jump_distance', 0)} 位",
                font=self.FONTS["body_bold"],
                fill=self.COLORS["warning_dark"]
            )

            # 绘制KMP跳转对比
            if hasattr(self, 'next_table') and step['j'] > 0:
                kmp_next = self.next_table[step['j'] - 1] if step['j'] - 1 < len(self.next_table) else 0
                kmp_jump = step['j'] - kmp_next

                if kmp_jump != step.get('jump_distance', 0):
                    # 显示KMP跳转距离对比
                    self.opt_canvas.create_text(
                        (old_x + new_x) / 2, pattern_y + char_height + 120,
                        text=f"KMP会跳转: {kmp_jump} 位 (可能漏检!)",
                        font=self.FONTS["small"],
                        fill=self.COLORS["danger"]
                    )

    def _draw_opt_scene(self, step_index):
        """绘制生物算法场景 - 简化版，去掉顶部标题栏和底部文字信息"""
        if not self.opt_steps:
            self.opt_canvas.delete("all")
            self.opt_canvas.create_text(400, 300,
                                        text="请先生成数据",
                                        font=self.FONTS["h3"],
                                        fill=self.COLORS["text_secondary"])
            return

        if step_index >= len(self.opt_steps):
            step_index = len(self.opt_steps) - 1

        self.opt_canvas.delete("all")
        step = self.opt_steps[step_index]

        # 获取画布尺寸
        canvas_width = self.opt_canvas.winfo_width() or 1000
        canvas_height = self.opt_canvas.winfo_height() or 700

        # 更新右侧信息面板（这部分保留在右侧面板中）
        self._update_opt_info_panel(step)

        # ========== 1. 计算布局参数 ==========
        n = len(self.text)
        m = len(self.pattern)

        # 增大字符大小
        total_chars_needed = max(n, m + step['i'] - step['j'])
        char_width = min(90, max(50, (canvas_width - 300) // max(1, total_chars_needed)))
        char_height = 90

        # ========== 2. 直接绘制文本串 ==========
        text_y = 80

        # 文本串标题
        self.opt_canvas.create_text(50, text_y - 55,
                                    text="📝 文本串:",
                                    font=self.FONTS["h4"],
                                    fill=self.COLORS["primary"],
                                    anchor="w")

        # 获取所有匹配信息
        found_matches = self._get_opt_found_matches(step_index)
        exclusive_matches = self._get_exclusive_opt_matches()

        # 绘制文本串字符
        for i, c in enumerate(self.text):
            char_x = 100 + i * char_width

            # 确定字符样式
            char_style = self._get_enhanced_char_style(i, step, found_matches, exclusive_matches)

            # 绘制字符方块
            self.opt_canvas.create_rectangle(
                char_x, text_y,
                char_x + char_width, text_y + char_height,
                fill=char_style["fill"],
                outline=char_style["outline"],
                width=2
            )

            # 增大字符字体
            self.opt_canvas.create_text(
                char_x + char_width / 2, text_y + char_height / 2,
                text=c,
                font=("Segoe UI", 24, "bold"),
                fill=char_style["text"]
            )

            # 增大索引字体
            self.opt_canvas.create_text(
                char_x + char_width / 2, text_y + char_height + 15,
                text=str(i),
                font=("Segoe UI", 14),
                fill=self.COLORS["text_tertiary"]
            )

            # 绘制特殊标记
            if "exclusive" in char_style["marks"]:
                # 生物算法特有匹配标记
                self.opt_canvas.create_rectangle(
                    char_x - 4, text_y - 4,
                    char_x + char_width + 4, text_y + char_height + 4,
                    outline=self.COLORS["success"],
                    width=3,
                    dash=(5, 2)
                )

        # 绘制主串指针
        if step['i'] < len(self.text):
            i_char_x = 100 + step['i'] * char_width + char_width / 2
            self.opt_canvas.create_line(
                i_char_x, text_y - 25,
                i_char_x, text_y - 5,
                fill=self.COLORS["primary"],
                width=5,
                arrow=tk.LAST
            )

            # 增大指针标签字体
            self.opt_canvas.create_text(
                i_char_x, text_y - 35,
                text=f"i={step['i']}",
                font=("Segoe UI", 18, "bold"),
                fill=self.COLORS["primary"]
            )

        # ========== 3. 绘制模式串 ==========
        pattern_y = text_y + char_height + 80
        pattern_start_x = 100 + (step['i'] - step['j']) * char_width

        # 模式串标题
        self.opt_canvas.create_text(50, pattern_y - 40,
                                    text="🔍 模式串:",
                                    font=self.FONTS["h4"],
                                    fill=self.COLORS["secondary"],
                                    anchor="w")

        # 绘制模式串字符
        for i, c in enumerate(self.pattern):
            char_x = pattern_start_x + i * char_width

            # 确定模式串字符样式
            pattern_style = self._get_enhanced_pattern_style(i, step)

            # 绘制字符方块
            self.opt_canvas.create_rectangle(
                char_x, pattern_y,
                char_x + char_width, pattern_y + char_height,
                fill=pattern_style["fill"],
                outline=pattern_style["outline"],
                width=2
            )

            # 增大模式串字符字体
            self.opt_canvas.create_text(
                char_x + char_width / 2, pattern_y + char_height / 2,
                text=c,
                font=("Segoe UI", 24, "bold"),
                fill=pattern_style["text"]
            )

            # 增大模式串索引字体
            self.opt_canvas.create_text(
                char_x + char_width / 2, pattern_y + char_height + 15,
                text=str(i),
                font=("Segoe UI", 14),
                fill=self.COLORS["text_tertiary"]
            )

        # 绘制模式串指针
        if step['j'] < len(self.pattern):
            j_char_x = pattern_start_x + step['j'] * char_width + char_width / 2
            self.opt_canvas.create_line(
                j_char_x, pattern_y + char_height + 45,
                j_char_x, pattern_y + char_height + 25,
                fill=self.COLORS["secondary"],
                width=5,
                arrow=tk.LAST
            )

            # 增大模式串指针标签字体
            self.opt_canvas.create_text(
                j_char_x, pattern_y + char_height + 50,
                text=f"j={step['j']}",
                font=("Segoe UI", 18, "bold"),
                fill=self.COLORS["secondary"]
            )

        # ========== 4. 绘制跳转箭头（如果发生跳转） ==========
        if step.get('jump_distance', 0) > 0 and step['j'] + step['jump_distance'] < len(self.pattern):
            old_j = step['j'] + step['jump_distance']
            old_x = pattern_start_x + old_j * char_width + char_width / 2
            new_x = pattern_start_x + step['j'] * char_width + char_width / 2

            # 绘制弯曲箭头
            self.opt_canvas.create_line(
                old_x, pattern_y + char_height + 40,
                       (old_x + new_x) / 2, pattern_y + char_height + 80,
                new_x, pattern_y + char_height + 40,
                arrow=tk.LAST,
                fill=self.COLORS["warning"],
                width=2,
                arrowshape=(10, 12, 6),
                smooth=True
            )

            # 增大跳转说明字体
            self.opt_canvas.create_text(
                (old_x + new_x) / 2, pattern_y + char_height + 100,
                text=f"安全跳转: {step['jump_distance']} 位",
                font=("Segoe UI", 16, "bold"),
                fill=self.COLORS["warning"]
            )

        # ========== 5. 自动滚动到焦点位置 ==========
        focus_position = step['i']
        focus_char_x = 100 + focus_position * char_width
        self._auto_scroll_to_position(focus_char_x, canvas_width)

        # 设置滚动区域
        self.opt_canvas.configure(scrollregion=self.opt_canvas.bbox("all"))

    def _get_opt_match_info(self, step_index):
        """获取生物算法的匹配信息"""
        found_matches = []
        exclusive_matches = []

        if hasattr(self, 'opt_steps') and self.opt_steps:
            # 获取生物算法的所有匹配
            for step in self.opt_steps[:step_index + 1]:
                if step.get('type') in ['found', 'found_by_verification']:
                    # 统一使用与KMP相同的计算方式
                    match_pos = step.get('i', 0) - len(self.pattern)
                    # 确保位置有效
                    if 0 <= match_pos < len(self.text):
                        found_matches.append(match_pos)

                        # 标记验证发现的匹配
                        if step.get('type') == 'found_by_verification':
                            exclusive_matches.append(match_pos)

        # 找出生物算法特有而KMP没有的匹配
        if hasattr(self, 'trad_steps') and self.trad_steps:
            kmp_matches = []
            for step in self.trad_steps:
                if step.get('type') == 'found':
                    match_pos = step.get('i', 0) - len(self.pattern)
                    if 0 <= match_pos < len(self.text):
                        kmp_matches.append(match_pos)

            # 找出生物算法特有匹配
            opt_set = set(found_matches)
            kmp_set = set(kmp_matches)
            exclusive_matches = list(opt_set - kmp_set)

        return found_matches, exclusive_matches

    def _draw_enhanced_statistics(self, canvas_width, found_matches, exclusive_matches, step):
        """绘制增强的统计信息"""
        stats_y = 650  # 根据画布高度调整

