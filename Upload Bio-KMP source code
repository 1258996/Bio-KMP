        self.opt_canvas.create_rectangle(
            50, stats_y - 30,
                canvas_width - 50, stats_y + 100,
            fill=self.COLORS["primary_light"],
            outline=self.COLORS["primary"],
            width=1
        )

        # 统计标题
        self.opt_canvas.create_text(
            canvas_width // 2, stats_y - 15,
            text="📊 算法性能统计",
            font=self.FONTS["h5"],
            fill=self.COLORS["primary_dark"]
        )

        # 匹配统计
        total_matches = len(set(found_matches))
        exclusive_count = len(set(exclusive_matches))
        memory_count = len(step.get('memory_queue', []))
        candidate_count = len(step.get('candidate_queue', []))

        stats = [
            (f"总匹配数: {total_matches}", self.COLORS["success"]),
            (f"生物算法特有: {exclusive_count}", self.COLORS["accent"]),
            (f"记忆队列: {memory_count} 项", self.COLORS["warning"]),
            (f"候选队列: {candidate_count} 项", self.COLORS["info"])
        ]

        for i, (text, color) in enumerate(stats):
            x_pos = 100 + i * 200 if i < 2 else 200 + (i - 2) * 200
            self.opt_canvas.create_text(
                x_pos, stats_y + 20,
                text=text,
                font=self.FONTS["body_bold"],
                fill=color,
                anchor="w"
            )

        # 算法优势说明
        if exclusive_count > 0:
            advantage_text = f"✅ 生物算法比KMP多发现 {exclusive_count} 个匹配！"
            self.opt_canvas.create_text(
                canvas_width // 2, stats_y + 60,
                text=advantage_text,
                font=self.FONTS["body_bold"],
                fill=self.COLORS["success"]
            )

            # 原因说明
            reason_text = "原因：记忆队列和候选队列防止了KMP跳转可能造成的漏检"
            self.opt_canvas.create_text(
                canvas_width // 2, stats_y + 85,
                text=reason_text,
                font=self.FONTS["small"],
