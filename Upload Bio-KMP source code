    def _get_opt_found_matches(self, step_index):
        """获取生物算法已找到的匹配位置"""
        found_matches = []
        if hasattr(self, 'opt_steps') and self.opt_steps:
            for step in self.opt_steps[:step_index + 1]:
                if step.get('type') == 'found':
                    match_pos = step.get('i', 0) - len(self.pattern)
                    if 0 <= match_pos < len(self.text):
                        found_matches.append(match_pos)
        return found_matches

    def _get_exclusive_opt_matches(self):
        """获取生物算法特有而KMP漏检的匹配位置"""
        if not hasattr(self, 'opt_steps') or not hasattr(self, 'trad_steps'):
            return []

        opt_matches = []
        kmp_matches = []

        # 获取生物算法匹配位置
        for step in self.opt_steps:
            if step.get('type') == 'found':
                match_pos = step.get('i', 0) - len(self.pattern)
                if 0 <= match_pos < len(self.text):
                    opt_matches.append(match_pos)

        # 获取KMP算法匹配位置
        for step in self.trad_steps:
            if step.get('type') == 'found':
                match_pos = step.get('i', 0) - len(self.pattern)
                if 0 <= match_pos < len(self.text):
                    kmp_matches.append(match_pos)

        # 找出生物算法特有而KMP漏检的
        exclusive = list(set(opt_matches) - set(kmp_matches))
        return exclusive

    def _ensure_list(self, data):
        """确保数据是列表类型"""
        if isinstance(data, list):
            return data
        elif isinstance(data, (tuple, set)):
            return list(data)
        elif isinstance(data, str) and data.startswith("["):
            try:
                import ast
                return ast.literal_eval(data)
            except:
                return []
        else:
            return []

