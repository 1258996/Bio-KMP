    def _calculate_gc_content(self):
        """计算GC含量"""
        dna_sequence = self.dna_entry.get().strip().upper()  # 使用dna_entry

        if not dna_sequence:
            messagebox.showwarning("警告", "DNA序列不能为空！")
            return

        gc_count = dna_sequence.count('G') + dna_sequence.count('C')
        gc_content = gc_count / len(dna_sequence) * 100
        at_content = 100 - gc_content

        result = f"DNA序列长度: {len(dna_sequence)}\n"
        result += f"GC含量: {gc_content:.2f}%\n"
        result += f"AT含量: {at_content:.2f}%\n"
        result += f"A: {dna_sequence.count('A')} ({dna_sequence.count('A') / len(dna_sequence) * 100:.1f}%)\n"
        result += f"T: {dna_sequence.count('T')} ({dna_sequence.count('T') / len(dna_sequence) * 100:.1f}%)\n"
        result += f"C: {dna_sequence.count('C')} ({dna_sequence.count('C') / len(dna_sequence) * 100:.1f}%)\n"
        result += f"G: {dna_sequence.count('G')} ({dna_sequence.count('G') / len(dna_sequence) * 100:.1f}%)\n"

        # 判断GC含量类型
        if gc_content > 60:
            result += "\n🔵 高GC区域 (可能为基因富集区)"
        elif gc_content < 40:
            result += "\n🟡 高AT区域 (可能为基因间区)"
        else:
            result += "\n🟢 中等GC含量"

        messagebox.showinfo("GC含量分析", result)

