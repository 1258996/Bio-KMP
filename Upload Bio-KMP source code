    def _draw_bf_scene(self, step_index):
        """绘制暴力算法场景"""
        if not self.bf_steps:
            self.bf_canvas.delete("all")
            self.bf_canvas.create_text(400, 300,
                                       text="请先生成数据",
                                       font=self.FONTS["h3"],
                                       fill=self.COLORS["text_secondary"])
            return

        if step_index >= len(self.bf_steps):
            step_index = len(self.bf_steps) - 1

        self.bf_canvas.delete("all")
        step = self.bf_steps[step_index]

        # 更新状态信息
        self.bf_i_pos.set(f"i指针: {step['i']} (开始于{step['start_i']})")
        self.bf_j_pos.set(f"j指针: {step['j']}")
        self.bf_action.set(f"当前动作: {step['action']}")
        self.bf_move_reason.set(f"匹配原因: {step.get('move_reason', '无')}")
        self.bf_match_count.set(f"已找到匹配: {step['match_count']}")
        self.bf_comparisons.set(f"字符比较次数: {step['comparison_count']}")

        self.bf_step_info.set(f"步骤: {step_index + 1}/{len(self.bf_steps)}")

        total_chars = len(self.text)
        canvas_width = self.bf_canvas.winfo_width() or 800
        available_width = canvas_width - 250

        if total_chars * self.SIZES["char_width"] > available_width:
            char_width = max(45, available_width // max(1, total_chars))
        else:
            char_width = self.SIZES["char_width"]

        char_height = self.SIZES["char_height"]

        text_y = self.SIZES["text_start_y"]
        self.bf_canvas.create_text(self.SIZES["title_offset_x"], text_y - self.SIZES["text_title_offset_y"],
                                   text="📝 文本串:",
                                   font=self.FONTS["h3"],
                                   fill=self.COLORS["primary"],
                                   anchor="w")

        # ========== 关键：计算需要滚动到的位置 ==========
        current_i = step['i']
        current_start_i = step['start_i']

        # 计算当前焦点位置（取主串指针和起始位置中较大的）
        focus_position = max(current_i, current_start_i)

        # 计算焦点字符的X坐标
        focus_char_x = self.SIZES["text_start_x"] + focus_position * char_width

        # 计算画布应该滚动到的位置
        viewport_width = canvas_width
        target_scroll_x = max(0, focus_char_x - viewport_width / 2)

        # 先绘制所有已找到的匹配
        found_matches = []
        for step_match in self.bf_steps[:step_index + 1]:
            if step_match.get('type') == 'found':
                match_pos = step_match.get('start_i', 0)
                if 0 <= match_pos < len(self.text):
                    found_matches.append(match_pos)

        # 绘制文本串字符
        for i, c in enumerate(self.text):
            char_x = self.SIZES["text_start_x"] + i * char_width

            # 检查当前位置是否在已找到的匹配中
            is_in_match = False
            for match_start in found_matches:
                if match_start <= i < match_start + len(self.pattern):
                    is_in_match = True
                    break

            # 检查是否是当前匹配的起始位置
            is_current_start = (i == step['start_i'])

            if is_in_match:
                fill_color = self.COLORS["success"]
                outline_color = self.COLORS["success_dark"]
                text_color = self.COLORS["bg"]
            elif is_current_start:
                fill_color = self.COLORS["warning"]
                outline_color = self.COLORS["warning_dark"]
                text_color = self.COLORS["bg"]
            elif i == step['i']:
                fill_color = self.COLORS["primary"]
                outline_color = self.COLORS["primary_dark"]
                text_color = self.COLORS["bg"]
            else:
                fill_color = self.COLORS["primary_light"]
                outline_color = self.COLORS["primary"]
                text_color = self.COLORS["primary_dark"]

            self.bf_canvas.create_rectangle(
                char_x, text_y,
                char_x + char_width, text_y + char_height,
                fill=fill_color, outline=outline_color, width=2
            )

            self.bf_canvas.create_text(
                char_x + char_width / 2, text_y + char_height / 2,
                text=c, font=self.FONTS["h4"], fill=text_color
            )

            self.bf_canvas.create_text(
                char_x + char_width / 2, text_y + char_height + self.SIZES["index_offset"],
                text=str(i), font=self.FONTS["body"], fill=self.COLORS["text_tertiary"]
            )

        # 绘制主串指针
        if step['i'] < len(self.text):
            i_char_x = self.SIZES["text_start_x"] + step['i'] * char_width + char_width / 2
            i_pointer_y = text_y - 20
            self._draw_pointer_with_label(self.bf_canvas, i_char_x, i_pointer_y,
                                          self.COLORS["warning"], f"i={step['i']}", f"比较位置", "down")

        # 绘制匹配起始位置指针
        if step['start_i'] < len(self.text):
            start_char_x = self.SIZES["text_start_x"] + step['start_i'] * char_width + char_width / 2
            start_pointer_y = text_y - 50
            self.bf_canvas.create_line(
                start_char_x, start_pointer_y,
                start_char_x, text_y - 25,
                fill=self.COLORS["info"],
                width=2,
                arrow=tk.LAST,
                arrowshape=(10, 12, 6)
            )
            self.bf_canvas.create_text(
                start_char_x, start_pointer_y - 10,
                text=f"start={step['start_i']}",
                font=self.FONTS["body"],
                fill=self.COLORS["info"],
                anchor="s"
            )

        pattern_y = text_y + char_height + self.SIZES["vertical_spacing"]
        pattern_start_x = self.SIZES["text_start_x"] + step['start_i'] * char_width

        self.bf_canvas.create_text(self.SIZES["title_offset_x"], pattern_y - self.SIZES["pattern_title_offset_y"],
                                   text="🔍 模式串:",
                                   font=self.FONTS["h3"],
                                   fill=self.COLORS["secondary"],
                                   anchor="w")

        # 绘制模式串
        for i, c in enumerate(self.pattern):
            char_x = pattern_start_x + i * char_width

            if i < step['j']:
                # 已匹配的部分
                if step['type'] == 'mismatch' and i == step['j']:
                    fill_color = self.COLORS["danger"]
                    outline_color = self.COLORS["danger_dark"]
                    text_color = self.COLORS["bg"]
                else:
                    fill_color = self.COLORS["success_light"]
                    outline_color = self.COLORS["success"]
                    text_color = self.COLORS["success_dark"]
            elif i == step['j']:
                # 当前正在比较的位置
                if step['type'] == 'mismatch' and step['is_matching']:
                    fill_color = self.COLORS["danger"]
                    outline_color = self.COLORS["danger_dark"]
                    text_color = self.COLORS["bg"]
                else:
                    fill_color = self.COLORS["primary"]
                    outline_color = self.COLORS["primary_dark"]
                    text_color = self.COLORS["bg"]
            else:
                # 未比较的部分
                fill_color = self.COLORS["secondary_light"]
                outline_color = self.COLORS["secondary"]
                text_color = self.COLORS["secondary_dark"]

            self.bf_canvas.create_rectangle(
                char_x, pattern_y,
                char_x + char_width, pattern_y + char_height,
                fill=fill_color, outline=outline_color, width=2
            )

            self.bf_canvas.create_text(
                char_x + char_width / 2, pattern_y + char_height / 2,
                text=c, font=self.FONTS["h4"], fill=text_color
            )

            self.bf_canvas.create_text(
                char_x + char_width / 2, pattern_y + char_height + self.SIZES["index_offset"],
                text=str(i), font=self.FONTS["body"], fill=self.COLORS["text_tertiary"]
            )

        # 绘制模式串指针
        if step['j'] < len(self.pattern):
            j_char_x = pattern_start_x + step['j'] * char_width + char_width / 2
            j_pointer_y = pattern_y + char_height + 60
            self._draw_pointer_with_label(self.bf_canvas, j_char_x, j_pointer_y,
                                          self.COLORS["danger"], f"j={step['j']}", f"比较第{step['j']}个字符", "up")

        # 如果是不匹配，显示回溯箭头
        if step['type'] == 'mismatch' and step['is_matching']:
            # 绘制回溯线
            current_char_x = self.SIZES["text_start_x"] + step['i'] * char_width + char_width / 2
            current_char_y = text_y + char_height / 2

            if step['start_i'] + 1 < len(self.text):
                next_start_x = self.SIZES["text_start_x"] + (step['start_i'] + 1) * char_width + char_width / 2
                next_start_y = text_y - 40

                # 绘制弯曲箭头
                self.bf_canvas.create_line(
                    current_char_x, current_char_y,
                    (current_char_x + next_start_x) / 2, text_y - 100,
                    next_start_x, next_start_y,
                    arrow=tk.LAST,
                    fill=self.COLORS["warning"],
                    width=2,
                    arrowshape=(10, 12, 6),
                    smooth=True
                )

                self.bf_canvas.create_text(
                    (current_char_x + next_start_x) / 2, text_y - 120,
                    text="回溯",
                    font=self.FONTS["body_bold"],
                    fill=self.COLORS["warning_dark"]
                )

        # ========== 自动滚动画布 ==========
        if hasattr(self, 'scroll_tracking_enabled') and self.scroll_tracking_enabled:
            # 获取当前画布的总宽度
            bbox = self.bf_canvas.bbox("all")
            if bbox:
                canvas_width_total = bbox[2] - bbox[0]
                # 计算滚动比例
                if canvas_width_total > viewport_width:
                    scroll_ratio = target_scroll_x / max(1, canvas_width_total - viewport_width)
                    scroll_ratio = max(0, min(1, scroll_ratio))

                    # 设置滚动位置
                    self.bf_canvas.xview_moveto(scroll_ratio)

        # 在焦点位置添加高亮标记（可选）
        if 0 <= focus_position < len(self.text):
            focus_char_x = self.SIZES["text_start_x"] + focus_position * char_width
            self.bf_canvas.create_rectangle(
                focus_char_x - 2, text_y - 5,
                focus_char_x + char_width + 2, text_y + char_height + 5,
                outline=self.COLORS["warning"],
                width=3,
                dash=(5, 2)
            )

        # 在顶部显示统计信息
        self.bf_canvas.create_text(
            canvas_width - 100, 50,
            text=f"🔍 暴力匹配算法",
            font=self.FONTS["h5"],
            fill=self.COLORS["warning"],
            anchor="e"
        )

        self.bf_canvas.create_text(
            canvas_width - 100, 80,
            text=f"已找到: {step['match_count']} 个匹配",
            font=self.FONTS["body"],
            fill=self.COLORS["success"],
            anchor="e"
        )

        self.bf_canvas.create_text(
            canvas_width - 100, 110,
            text=f"比较次数: {step['comparison_count']}",
            font=self.FONTS["body"],
            fill=self.COLORS["info"],
            anchor="e"
        )

        # 显示当前状态
        status_text = ""
        if step['type'] == 'match':
            status_text = "✅ 字符匹配"
        elif step['type'] == 'mismatch':
            status_text = "❌ 字符不匹配"
        elif step['type'] == 'found':
            status_text = "🎯 找到完整匹配"
        elif step['type'] == 'end':
            status_text = "🏁 匹配结束"

        if status_text:
            self.bf_canvas.create_text(
                canvas_width - 100, 140,
                text=status_text,
                font=self.FONTS["body_bold"],
                fill=self.COLORS["warning_dark"] if step['type'] == 'mismatch' else self.COLORS["success"],
                anchor="e"
            )

        self.bf_canvas.configure(scrollregion=self.bf_canvas.bbox("all"))
