            # 当前比较位置
            style["fill"] = self.COLORS["primary"]
            style["outline"] = self.COLORS["primary_dark"]
            style["text"] = self.COLORS["bg"]
            style["marks"].append("current")
            style["special_marks"].append("📍")

        elif is_current_match_start:
            # 当前匹配起始位置
            style["fill"] = self.COLORS["warning_light"]
            style["outline"] = self.COLORS["warning"]
            style["text"] = self.COLORS["warning_dark"]
            style["marks"].append("start")
            style["special_marks"].append("🚩")

        elif is_in_candidate_queue:
            # 候选队列位置
