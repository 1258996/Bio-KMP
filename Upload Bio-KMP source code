    def _generate_trad_steps(self):
        """生成传统方法的步骤 - 添加比较计数器"""
        self.trad_steps = []
        m = len(self.pattern)
        n = len(self.text)

        i = 0
        j = 0
        step_num = 0
        match_count = 0
        comparison_count = 0  # 比较计数器

        while i <= n:
            step_num += 1

            step = {
                'step': step_num,
                'i': i,
                'j': j,
                'type': 'start' if step_num == 1 else 'continue',
                'text_char': self.text[i] if i < n else '',
                'pattern_char': self.pattern[j] if j < m else '',
                'action': '',
                'match_len': j,
                'next_val': self.next_table[j - 1] if j > 0 else 0 if step_num > 1 else -1,
                'comparison_count': comparison_count  # 添加比较计数
            }

            if j == m:
                step['type'] = 'found'
                step['action'] = f'✅ 找到第{match_count + 1}个匹配，位置: {i - j}'
                step['move_reason'] = f'模式串完全匹配成功！j指针跳转到next[{m - 1}]={self.next_table[m - 1]}继续匹配'
                match_count += 1

                # 找到匹配后，j跳转到next[j-1]继续匹配
                j = self.next_table[m - 1] if m > 0 else 0
                self.trad_steps.append(step)
                continue

            if i == n:
                step['type'] = 'end'
                step['action'] = f'匹配结束，共找到{match_count}个匹配'
                step['move_reason'] = f'文本串已遍历完成，找到{match_count}个匹配位置'
                self.trad_steps.append(step)
                break

            # 字符比较
            if i < n and j < m:
                comparison_count += 1
                step['comparison_count'] = comparison_count

            if self.text[i] == self.pattern[j]:
                step['type'] = 'match'
                step['action'] = f'字符匹配: text[{i}]="{self.text[i]}" == pattern[{j}]="{self.pattern[j]}"'
                step['move_reason'] = '字符相同，继续比较下一个字符'
                i += 1
                j += 1
            else:
                step['type'] = 'mismatch'
                step['action'] = f'字符不匹配: text[{i}]="{self.text[i]}" != pattern[{j}]="{self.pattern[j]}"'
                if j == 0:
                    step['move_reason'] = '模式串第一个字符就不匹配，i指针后移'
                    i += 1
                else:
                    step['move_reason'] = f'已匹配{j}个字符，j指针跳转到next[{j - 1}]={self.next_table[j - 1]}'
                    j = self.next_table[j - 1]

            self.trad_steps.append(step)

        self.trad_step_info.set(f"步骤: 0/{len(self.trad_steps)}")

    def _generate_opt_steps_fixed(self):
        """生成生物KMP算法的步骤 - 完全遵循精要算法逻辑"""
        self.opt_steps = []

        if not hasattr(self, 'text') or not self.text or not hasattr(self, 'pattern') or not self.pattern:
            return

        n = len(self.text)
        m = len(self.pattern)

        if m > n:
            return

        # ========== 步骤一：初始化 ==========
        i = 0  # 主串指针
        j = 0  # 模式串指针
        step_num = 0
        match_count = 0
        all_matches = []  # 记录所有匹配位置

        # 初始化队列
        memory_queue = deque()  # 记忆队列：记录跳过的潜在起点
        candidate_queue = deque()  # 候选队列：记录部分匹配的候选位置

        # 设置验证窗口大小 L（默认 L = min(m/2, 最大重复单元长度)）
        L = self._calculate_verification_window_exact(self.pattern)

        # 步骤记录：初始化
        step_num += 1
        self.opt_steps.append({
            'step': step_num,
            'i': i,
            'j': j,
            'type': 'init',
            'action': '初始化生物算法',
            'move_reason': f'设置验证窗口L={L}，初始化空记忆队列和候选队列',
            'memory_queue': list(memory_queue),
            'candidate_queue': list(candidate_queue),
            'window_size': L,
            'jump_distance': 0,
            'match_len': j,
            'match_count': match_count,
            'match_position': None
        })

        # ========== 步骤二：主匹配循环 ==========
        while i < n:
            step_num += 1
            step = {
                'step': step_num,
                'i': i,
                'j': j,
                'type': 'compare',
                'action': '',
                'move_reason': '',
                'memory_queue': list(memory_queue),
                'candidate_queue': list(candidate_queue),
                'window_size': L,
                'jump_distance': 0,
                'match_len': j,
                'match_count': match_count,
                'match_position': None
            }

            # ========== 情况A：匹配成功 ==========
            if j < m and i < n and self.text[i] == self.pattern[j]:
                step['type'] = 'match'
                step['action'] = f'字符匹配: S[{i}]="{self.text[i]}" == P[{j}]="{self.pattern[j]}"'
                step['move_reason'] = '字符匹配成功，i和j指针都向后移动'

                i += 1
                j += 1

                # 检查是否完全匹配
                if j == m:
                    # 找到完整匹配
                    match_pos = i - m
                    match_count += 1
                    all_matches.append(match_pos)

                    step['type'] = 'found'
                    step['action'] = f'✅ 找到第{match_count}个匹配，位置: {match_pos}'
                    step['move_reason'] = '模式串完全匹配成功！'
                    step['match_count'] = match_count
                    step['match_position'] = match_pos

                    # 计算重叠匹配长度 k（使 P[0..k-1] == P[m-k..m-1] 的最大 k）
                    overlap_k = 0
                    for k in range(1, m):
                        if self.pattern[:k] == self.pattern[m - k:]:
                            overlap_k = k

                    # 设置 j = k，i 不变
                    j = overlap_k
                    step['j'] = j
                    step['move_reason'] += f'，计算重叠长度k={overlap_k}，j跳转到{overlap_k}继续匹配'

            # ========== 情况B：匹配失败 ==========
            elif j < m and i < n and self.text[i] != self.pattern[j]:
                step['type'] = 'mismatch'
                step['action'] = f'字符不匹配: S[{i}]="{self.text[i]}" != P[{j}]="{self.pattern[j]}"'

                if j == 0:
                    # 模式串开头就不匹配
                    step['move_reason'] = '模式串第一个字符不匹配，i指针后移'
                    i += 1
                else:
                    # 已匹配部分字符后不匹配
                    # 计算最小安全跳转
                    jump_distance = self._calculate_min_safe_jump(self.pattern, j, L)
                    step['jump_distance'] = jump_distance

                    # 记忆标记：将跳过的 k-1 个位置加入队列 Q
                    current_start = i - j
                    for k_pos in range(1, jump_distance):
                        skipped_pos = current_start + k_pos
                        if skipped_pos < n and skipped_pos not in memory_queue:
                            memory_queue.append(skipped_pos)

                    # 候选检测：检查队列 Q 中位置是否可能为新起点
                    self._check_candidate_positions(memory_queue, candidate_queue, i, j)

                    # 执行跳转
                    j = j - jump_distance
                    step['j'] = j
                    step['move_reason'] = f'计算最小安全跳转距离k={jump_distance}，j从{j + jump_distance}跳转到{j}'

            # ========== 主串结束检查 ==========
            elif i >= n:
                step['type'] = 'end'
                step['action'] = f'主串遍历完成，共找到{match_count}个匹配'
                step['move_reason'] = '主串指针i已到达末尾'
                self.opt_steps.append(step)
                break

            # ========== 候选处理 ==========
            # 触发条件：主匹配空闲或队列满时
            if (len(candidate_queue) > 0 and
                    (step_num % 5 == 0 or len(candidate_queue) >= 10)):

                step_num += 0.1  # 使用小数表示子步骤
                process_step = {
                    'step': step_num,
                    'i': i,
                    'j': j,
                    'type': 'candidate_process',
                    'action': f'处理候选队列（{len(candidate_queue)}个候选）',
                    'move_reason': '',
                    'memory_queue': list(memory_queue),
                    'candidate_queue': list(candidate_queue),
                    'window_size': L,
                    'jump_distance': 0,
                    'match_len': j,
                    'match_count': match_count,
                    'match_position': None
                }

                # 遍历候选队列 C 中每个候选位置 pos
                valid_candidates = []
                while candidate_queue:
                    candidate = candidate_queue.popleft()
                    if isinstance(candidate, dict) and 'pos' in candidate:
                        cand_pos = candidate['pos']
                        matched_len = candidate.get('matched_len', 0)

                        # 验证 S[pos..pos+已匹配长度-1] 与 P 前缀的匹配
                        if self._verify_candidate(cand_pos, matched_len):
                            # 若验证通过，创建新匹配实例继续
                            valid_candidates.append(candidate)
                            process_step['move_reason'] += f'位置{cand_pos}验证通过；'
                        else:
                            # 若验证失败，移除该候选
                            process_step['move_reason'] += f'位置{cand_pos}验证失败；'

                # 重新添加有效候选
                for cand in valid_candidates:
                    candidate_queue.append(cand)

                process_step['candidate_queue'] = list(candidate_queue)
                self.opt_steps.append(process_step)

            # 更新步骤状态
            step['i'] = i
            step['j'] = j
            step['match_len'] = j
            step['match_count'] = match_count
            step['memory_queue'] = list(memory_queue)
            step['candidate_queue'] = list(candidate_queue)

            self.opt_steps.append(step)

            # 队列大小限制
            if len(memory_queue) > 20:
                memory_queue = deque(list(memory_queue)[-20:])
            if len(candidate_queue) > 10:
                candidate_queue = deque(list(candidate_queue)[-10:])

        # ========== 步骤四：终止 ==========
        step_num += 1
        self.opt_steps.append({
            'step': step_num,
            'i': i,
            'j': j,
            'type': 'end',
            'action': f'匹配结束，共找到{match_count}个匹配',
            'move_reason': f'主串遍历完成，记忆队列{len(memory_queue)}项，候选队列{len(candidate_queue)}项',
            'memory_queue': list(memory_queue),
            'candidate_queue': list(candidate_queue),
            'window_size': L,
            'jump_distance': 0,
            'match_len': j,
            'match_count': match_count,
            'match_position': None
        })

        # 更新步骤信息
        self.opt_step_info.set(f"步骤: 0/{len(self.opt_steps)}")

        print(f"生物算法步骤生成完成，共 {len(self.opt_steps)} 步")
        print(f"找到 {match_count} 个匹配: {all_matches}")

        return all_matches
    def _validate_optimization_algorithm(self, opt_matches):
        """验证生物算法的正确性"""
        if not hasattr(self, 'text') or not hasattr(self, 'pattern'):
            return

        # 暴力算法的匹配结果作为基准
        bf_matches = []
        n = len(self.text)
        m = len(self.pattern)

        for i in range(n - m + 1):
            if self.text[i:i + m] == self.pattern:
                bf_matches.append(i)

        # KMP算法的匹配结果
        kmp_matches = []
        if hasattr(self, 'trad_steps'):
            for step in self.trad_steps:
                if step.get('type') == 'found':
                    match_pos = step.get('i', 0) - m
                    if 0 <= match_pos < n:
                        kmp_matches.append(match_pos)
            kmp_matches = list(set(kmp_matches))  # 去重

        # 去重并排序
        bf_set = sorted(set(bf_matches))
        kmp_set = sorted(set(kmp_matches))
        opt_set = sorted(set(opt_matches))

        print("\n" + "=" * 50)
        print("算法结果验证:")
        print(f"暴力算法: {len(bf_set)}个匹配 {bf_set}")
        print(f"KMP算法: {len(kmp_set)}个匹配 {kmp_set}")
        print(f"生物算法: {len(opt_set)}个匹配 {opt_set}")

        # 检查生物算法是否漏检
        opt_missing = set(bf_set) - set(opt_set)
        opt_extra = set(opt_set) - set(bf_set)

        if opt_missing:
            print(f"⚠️ 生物算法漏检: {sorted(list(opt_missing))}")
        else:
            print("✅ 生物算法无漏检")

        if opt_extra:
            print(f"⚠️ 生物算法多检: {sorted(list(opt_extra))}")

        # 与KMP算法比较
        kmp_missing = set(bf_set) - set(kmp_set)
        if kmp_missing and not opt_missing:
            print(f"🎯 生物算法成功捕获KMP漏检: {sorted(list(kmp_missing))}")

        print("=" * 50)

    def _is_kmp_miss_case(self, current_pos, j, jump_distance):
        """判断是否是KMP可能漏检的经典情况"""
        # 检查是否是经典案例：模式串有长重叠部分
        if len(self.pattern) >= 5:
            # 检查模式串是否有显著的前缀后缀重叠
            overlap_len = 0
            for k in range(1, len(self.pattern)):
                if self.pattern[:k] == self.pattern[-k:]:
                    overlap_len = k

            # 如果重叠长度较大，且跳转距离较大，可能是KMP漏检情况
            if overlap_len > len(self.pattern) // 3 and jump_distance > overlap_len:
                return True

        # 特定经典案例的检测
        classic_patterns = [
            "ABABCABAB",  # 经典KMP漏检案例
            "AAAAB",  # 明显跳转漏检
            "ABCABCA",  # 重复模式
        ]

        for pattern in classic_patterns:
            if self.pattern == pattern:
                return True

        return False

    def _analyze_kmp_vs_opt_differences(self):
        """分析KMP和生物算法的差异"""
        if not hasattr(self, 'trad_steps') or not self.trad_steps or not hasattr(self,
                                                                                 'opt_steps') or not self.opt_steps:
            return

        # 获取两种算法的匹配位置
        kmp_matches = []
        opt_matches = []

        # 从KMP步骤中提取匹配
        for step in self.trad_steps:
            if step.get('type') == 'found':
                match_pos = step.get('i', 0) - len(self.pattern)
                if 0 <= match_pos < len(self.text):
                    kmp_matches.append(match_pos)

        # 从生物算法步骤中提取匹配
        for step in self.opt_steps:
            if step.get('type') in ['found', 'found_by_verification']:
                match_pos = step.get('match_position', step.get('i', 0) - len(self.pattern))
                if 0 <= match_pos < len(self.text):
                    opt_matches.append(match_pos)

        # 去重
        kmp_matches = sorted(list(set(kmp_matches)))
        opt_matches = sorted(list(set(opt_matches)))

        # 找出差异
        kmp_only = set(kmp_matches) - set(opt_matches)
        opt_only = set(opt_matches) - set(kmp_matches)

        # 生成分析报告
        report = "🧬 KMP vs 生物算法对比分析\n"
        report += "=" * 60 + "\n\n"

        report += f"📊 基本数据：\n"
        report += f"• 文本串长度: {len(self.text)}\n"
        report += f"• 模式串长度: {len(self.pattern)}\n"
        report += f"• 模式串: {self.pattern}\n\n"

        report += f"📈 匹配结果：\n"
        report += f"• KMP算法找到匹配: {len(kmp_matches)} 个\n"
        report += f"• 生物算法找到匹配: {len(opt_matches)} 个\n\n"

        if opt_only:
            report += f"🎯 关键发现：\n"
            report += f"• 生物算法多找到 {len(opt_only)} 个匹配！\n"
            report += f"• 生物算法特有匹配位置: {sorted(list(opt_only))}\n\n"

            report += f"🔍 原因分析：\n"
            report += "KMP算法可能因为以下原因漏检：\n"
            report += "1. Next数组跳转距离过长\n"
            report += "2. 忽略了部分重叠的匹配起始位置\n"
            report += "3. 没有回溯验证机制\n\n"

            report += f"✅ 生物算法改进：\n"
            report += "1. 记忆队列记录所有跳过的位置\n"
            report += "2. 候选队列监控部分匹配\n"
            report += "3. 验证队列检查KMP可能漏检的位置\n"
            report += "4. 多重保障确保不遗漏任何匹配\n"
        elif kmp_only:
            report += f"⚠️ 特殊情况：\n"
            report += f"• KMP算法多找到 {len(kmp_only)} 个匹配\n"
            report += f"• 这可能是因为生物算法过于保守\n"
        else:
            report += f"✅ 完美一致：\n"
            report += "• 两种算法找到完全相同的匹配位置\n"

        report += "\n" + "=" * 60

        # 在右侧信息面板显示
        if hasattr(self, 'validation_result_text'):
            self.validation_result_text.config(state='normal')
            self.validation_result_text.delete(1.0, tk.END)
            self.validation_result_text.insert(1.0, report)
            self.validation_result_text.config(state='disabled')

        return report

