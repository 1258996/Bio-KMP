    def _draw_pointer(self, canvas, x, y, color, label, direction, tooltip=""):
        """绘制指针"""
        pointer_length = 40

        if direction == "down":
            # 向下箭头
            canvas.create_line(
                x, y,
                x, y + pointer_length,
                fill=color,
                width=3,
                arrow=tk.LAST,
                arrowshape=(12, 15, 8)
