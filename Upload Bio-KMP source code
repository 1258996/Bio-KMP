    def _generate_comprehensive_validation_report(self, bf_matches, kmp_matches, opt_matches,
                                                  bf_comparisons, kmp_comparisons, opt_comparisons):
        """生成包含算法总结的验证报告"""
        n = len(self.text)
        m = len(self.pattern)

        report = "🧬 基因序列算法综合分析报告\n"
        report += "=" * 80 + "\n\n"

        # 1. 数据概览
        report += "📊 数据概览\n"
        report += f"- DNA序列长度: {n} 个碱基\n"
        report += f"- 搜索模式长度: {m} 个碱基\n"
        report += f"- 搜索模式: {self.pattern}\n"

        # 计算GC含量
        if hasattr(self, 'text') and self.text:
            gc_count = self.text.count('G') + self.text.count('C')
            gc_content = gc_count / max(1, n) * 100
            report += f"- GC含量: {gc_content:.1f}%\n"

        report += "\n"

        # 2. 性能对比总结（从原性能对比页面移过来的部分）
        report += "⚡ 算法性能对比总结\n"
        report += "=" * 40 + "\n"
        report += f"暴力算法比较次数: {bf_comparisons:,}\n"
        report += f"KMP算法比较次数: {kmp_comparisons:,}\n"
        report += f"生物算法比较次数: {opt_comparisons:,}\n"

        # 计算效率提升
        if bf_comparisons > 0:
            kmp_improvement = (bf_comparisons - kmp_comparisons) / bf_comparisons * 100
            opt_improvement = (bf_comparisons - opt_comparisons) / bf_comparisons * 100
            report += f"\n🔝 效率提升\n"
            report += f"- KMP相比暴力算法: {kmp_improvement:.1f}%\n"
            report += f"- 生物算法相比暴力算法: {opt_improvement:.1f}%\n"
            if opt_comparisons < kmp_comparisons:
                opt_vs_kmp = (kmp_comparisons - opt_comparisons) / kmp_comparisons * 100
                report += f"- 生物算法相比KMP: {opt_vs_kmp:.1f}%\n"

        report += "\n"

        # 3. 匹配结果对比
        report += "🎯 匹配结果对比\n"
        report += "=" * 40 + "\n"
