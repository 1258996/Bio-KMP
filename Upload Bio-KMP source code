    def _show_all_matches(self):
        """显示所有匹配位置"""
        if not self.text or not self.pattern:
            messagebox.showinfo("提示", "请先生成数据！")
            return

        matches = []
        n = len(self.text)
        m = len(self.pattern)

        # 简单查找所有匹配
        for i in range(n - m + 1):
            if self.text[i:i + m] == self.pattern:
                matches.append(i)

        if matches:
            message = f"模式 '{self.pattern}' 在文本中共出现 {len(matches)} 次:\n\n"
            for idx, pos in enumerate(matches, 1):
                message += f"{idx}. 位置 {pos}: {self.text[max(0, pos - 3):pos]}[{self.pattern}]{self.text[pos + m:pos + m + 3]}\n"
            messagebox.showinfo("匹配结果", message)
        else:
            messagebox.showinfo("匹配结果", f"未找到模式 '{self.pattern}'")
