            report += f"   • 相比暴力算法提升: {metrics['opt_improvement']:.1f}%\n"
        if metrics['opt_vs_kmp_improvement'] > 0:
            report += f"   • 相比KMP算法提升: {metrics['opt_vs_kmp_improvement']:.1f}%\n"
        if metrics['opt_matches'] > 0:
            report += f"   • 匹配位置: {sorted(list(set(opt_data['match_positions'])))[:5]}"
            if len(set(opt_data['match_positions'])) > 5:
                report += f" ... (共{len(set(opt_data['match_positions']))}个)"
            report += "\n"
        report += "\n"

        # 性能对比总结
        report += "📈 性能对比总结\n"
        report += "=" * 40 + "\n"

        if metrics['bf_comparisons'] > 0:
            report += f"• KMP算法效率提升: {metrics['kmp_improvement']:.1f}%\n"
            report += f"• 生物算法效率提升: {metrics['opt_improvement']:.1f}%\n"
            report += f"• 生物算法相比KMP额外提升: {metrics['opt_vs_kmp_improvement']:.1f}%\n"
        else:
            report += "• 所有算法在第一次比较即完成匹配\n"

        # 匹配结果一致性
        report += "\n✅ 匹配结果验证\n"
        report += "=" * 40 + "\n"

        if metrics['matches_consistent']:
            report += "🎉 所有算法找到的匹配位置完全一致！\n"
        else:
            report += "⚠️ 算法匹配结果存在差异：\n"
            if metrics['bf_unique_matches'] > 0:
                report += f"   • 暴力算法特有匹配: {metrics['bf_unique_matches']} 个\n"
            if metrics['kmp_unique_matches'] > 0:
                report += f"   • KMP算法特有匹配: {metrics['kmp_unique_matches']} 个\n"
            if metrics['opt_unique_matches'] > 0:
                report += f"   • 生物算法特有匹配: {metrics['opt_unique_matches']} 个\n"
            report += "   (提示：请检查算法实现或数据特征)\n"

        # 空间复杂度分析
        report += "\n💾 空间复杂度分析\n"
        report += "=" * 40 + "\n"
        report += "• 暴力算法: O(1) - 仅需两个指针\n"
        report += f"• KMP算法: O(m) = O({m}) - 存储next数组\n"
        report += f"• 生物算法: O(m+n) ≈ O({m}+{n}) - next数组+队列系统\n"

        # 算法选择建议
        report += "\n💡 算法选择建议\n"
        report += "=" * 40 + "\n"

        recommendation = self._generate_recommendation(metrics, n, m)
        report += recommendation

        # 大数据量性能预测
        report += "\n🔮 大数据量性能预测\n"
        report += "=" * 40 + "\n"

        if n < 1000:  # 当前数据规模较小
            report += f"基于当前数据规模({n})的预测：\n"
            report += f"• 当n=1000, m={m}时：\n"
            report += f"  - 暴力算法：约{1000 * m:,}次比较\n"
            report += f"  - KMP算法：约{1000 + m:,}次比较\n"
            report += f"  - 效率提升：约{(1000 * m) / max(1, 1000 + m):.1f}倍\n"
        else:
            report += "当前数据规模已经较大，结果具有代表性。\n"

        # 关键步骤示例
        report += "\n🔍 关键步骤示例（每种算法前3步）\n"
        report += "=" * 40 + "\n"

        report += "暴力算法:\n"
        for i, step in enumerate(bf_data['step_details'][:3]):
            report += f"  步骤{step['step']}: i={step['i']}, j={step['j']} - {step['action'][:50]}...\n"

        report += "\nKMP算法:\n"
        for i, step in enumerate(kmp_data['step_details'][:3]):
            report += f"  步骤{step['step']}: i={step['i']}, j={step['j']}, next={step['next_val']} - {step['action'][:50]}...\n"

        report += "\n生物算法:\n"
        for i, step in enumerate(opt_data['step_details'][:3]):
            report += f"  步骤{step['step']}: i={step['i']}, j={step['j']}, 跳转={step['jump_distance']} - {step['action'][:50]}...\n"

        # 报告结尾
        report += "\n" + "=" * 80 + "\n"
        report += f"✨ 分析完成时间: {self._get_current_time()}\n"
        report += "📊 系统版本: 基因序列模式匹配分析系统 v2.0\n"
        report += "=" * 80

        return report

    def _generate_recommendation(self, metrics, n, m):
        """生成算法选择建议"""
        recommendation = ""

        # 根据效率提升判断
        if metrics['kmp_improvement'] > 70:
            recommendation += "✅ 强烈推荐使用KMP算法：\n"
            recommendation += "   • 效率提升显著（超过70%）\n"
            recommendation += "   • 适合当前数据规模和模式特征\n"
            recommendation += "   • 内存消耗适中\n"
        elif metrics['kmp_improvement'] > 30:
            recommendation += "✅ 推荐使用KMP算法：\n"
            recommendation += "   • 有明显的效率提升\n"
            recommendation += "   • 综合性能最优\n"
        elif metrics['opt_improvement'] > metrics['kmp_improvement']:
            recommendation += "✅ 推荐使用生物算法：\n"
            recommendation += "   • 在KMP基础上进一步生物\n"
            recommendation += "   • 适合高精度需求\n"
            recommendation += "   • 提供多重保障机制\n"
        else:
            recommendation += "📌 根据当前数据特征：\n"
            recommendation += "   • 三种算法性能相近\n"
            recommendation += "   • 可根据具体需求选择\n"

        # 根据模式长度补充建议
        if m <= 3:
            recommendation += "   • 模式较短，暴力算法也可考虑\n"
        elif m >= 10:
            recommendation += "   • 模式较长，KMP和生物算法优势明显\n"

        # 根据序列特征补充建议
        if hasattr(self, 'pattern') and self.pattern:
            # 检查是否为重复模式
            if self.pattern in ["AGC", "AT", "GAA", "CAG"]:
                recommendation += "   • 检测到串联重复模式，特别适合KMP算法\n"

            # 检查是否为DNA特殊序列
            dna_patterns = ["GC", "CG", "TATA", "GAATTC"]
            if any(pattern in self.pattern for pattern in dna_patterns):
                recommendation += "   • 检测到DNA特征序列，建议使用生物算法确保准确性\n"

        # 通用建议
        recommendation += "\n🎯 通用选择指南：\n"
        recommendation += "1. 简单应用/内存受限：暴力算法\n"
        recommendation += "2. 常规搜索需求：KMP算法（最佳平衡）\n"
        recommendation += "3. 高精度/DNA分析：生物算法\n"
        recommendation += "4. 实时系统：KMP算法（响应最快）\n"

        return recommendation

    def _update_report_textbox(self, report_text):
        """更新报告文本框"""
        self.comparison_report.config(state='normal')
        self.comparison_report.delete(1.0, tk.END)
        self.comparison_report.insert(1.0, report_text)
        self.comparison_report.config(state='disabled')

        # 添加语法高亮（简化版）
        self._add_text_highlighting()

    def _add_text_highlighting(self):
        """为报告文本添加语法高亮"""
        # 标题高亮
        self.comparison_report.tag_config('title', foreground=self.COLORS["primary"], font=self.FONTS["h5"])
        self.comparison_report.tag_config('subtitle', foreground=self.COLORS["secondary"], font=self.FONTS["body_bold"])

        # 算法名称高亮
        self.comparison_report.tag_config('algorithm', foreground=self.COLORS["warning_dark"],
                                          font=self.FONTS["body_bold"])
        self.comparison_report.tag_config('kmp', foreground=self.COLORS["primary"], font=self.FONTS["body_bold"])
        self.comparison_report.tag_config('opt', foreground=self.COLORS["accent"], font=self.FONTS["body_bold"])

        # 数据高亮
        self.comparison_report.tag_config('data', foreground=self.COLORS["success"])
        self.comparison_report.tag_config('warning', foreground=self.COLORS["warning"])
        self.comparison_report.tag_config('success', foreground=self.COLORS["success"], font=self.FONTS["body_bold"])

        # 应用高亮（简化版）
        text = self.comparison_report.get(1.0, tk.END)
        lines = text.split('\n')

        for i, line in enumerate(lines, 1):
            start_idx = f"{i}.0"
            if line.startswith("🧬"):
                self.comparison_report.tag_add('title', start_idx, f"{i}.{len(line)}")
            elif line.startswith("📊") or line.startswith("⚡") or line.startswith("💾") or line.startswith("💡"):
                self.comparison_report.tag_add('subtitle', start_idx, f"{i}.{len(line)}")
            elif "暴力算法" in line:
                self.comparison_report.tag_add('algorithm', start_idx, f"{i}.{len(line)}")
            elif "KMP算法" in line:
                self.comparison_report.tag_add('kmp', start_idx, f"{i}.{len(line)}")
            elif "生物算法" in line:
                self.comparison_report.tag_add('opt', start_idx, f"{i}.{len(line)}")
            elif "✅" in line or "🎉" in line:
                self.comparison_report.tag_add('success', start_idx, f"{i}.{len(line)}")
            elif "⚠️" in line:
                self.comparison_report.tag_add('warning', start_idx, f"{i}.{len(line)}")

    def _draw_comparison_chart(self, bf_count, kmp_count, opt_count):
        """绘制简洁的字符比较次数对比图表"""
        try:
            if not hasattr(self, 'comparison_canvas'):
                print("错误：comparison_canvas 不存在")
                return

            self.comparison_canvas.delete("all")

            # 获取画布尺寸
            canvas_width = self.comparison_canvas.winfo_width() or 900
            canvas_height = 350  # 固定高度

            # ========== 1. 图表标题 ==========
            title_y = 30
            self.comparison_canvas.create_text(
                canvas_width // 2, title_y,
                text="📊 字符比较次数对比",
                font=self.FONTS["h3"],
                fill=self.COLORS["primary"],
                anchor="center"
            )

            # ========== 2. 数据概览 ==========
            if hasattr(self, 'text') and hasattr(self, 'pattern'):
                n = len(self.text) if self.text else 0
                m = len(self.pattern) if self.pattern else 0
                info_y = 60

                # 数据规模信息
                self.comparison_canvas.create_text(
                    canvas_width // 2, info_y,
                    text=f"数据规模: 文本串长度={n}, 模式串长度={m}",
                    font=self.FONTS["body"],
                    fill=self.COLORS["text_secondary"],
                    anchor="center"
                )

            # ========== 3. 柱状图区域 ==========
            chart_y = 90  # 降低图表位置
            chart_width = canvas_width - 100
            chart_height = 200

            # 算法数据
            algorithms = [
                {"name": "暴力算法", "value": bf_count, "color": self.COLORS["warning"],
                 "icon": "⚔️", "abbr": "BF"},
                {"name": "KMP算法", "value": kmp_count, "color": self.COLORS["primary"],
                 "icon": "📘", "abbr": "KMP"},
                {"name": "生物算法", "value": opt_count, "color": self.COLORS["accent"],
                 "icon": "⚡", "abbr": "OPT"}
            ]

            # 找到最大值用于归一化
            max_value = max(algo["value"] for algo in algorithms)
            if max_value == 0:
                max_value = 1  # 避免除零错误

            # 坐标轴设置
            axis_x_start = 80
            axis_x_end = axis_x_start + chart_width - 60
            axis_y_start = chart_y + 40
            axis_y_end = chart_y + chart_height - 30

            # 绘制坐标轴
            self._draw_chart_axes(axis_x_start, axis_y_start, axis_x_end, axis_y_end, max_value)

            # 绘制柱状图
            bar_width = 80
            bar_spacing = 40
            start_x = axis_x_start + 50

            for i, algo in enumerate(algorithms):
                x = start_x + i * (bar_width + bar_spacing)

                # 计算柱子高度
                bar_height = (algo["value"] / max_value) * (axis_y_end - axis_y_start - 40)
                if bar_height < 10:  # 最小高度
                    bar_height = 10

                # 绘制柱子
                y_top = axis_y_end - bar_height

                # 柱子主体
                self.comparison_canvas.create_rectangle(
                    x, y_top,
                    x + bar_width, axis_y_end,
                    fill=algo["color"],
                    outline=algo["color"],
                    width=2
                )

                # 添加渐变效果
                for j in range(3):
                    shade_y = y_top + j * 4
                    shade_color = self._adjust_color(algo["color"], -15 + j * 8)
                    self.comparison_canvas.create_line(
                        x, shade_y,
                        x + bar_width, shade_y,
                        fill=shade_color,
                        width=1
                    )

                # 显示数值
                value_text = self._format_number(algo["value"])
                self.comparison_canvas.create_text(
                    x + bar_width / 2, y_top - 15,
                    text=value_text,
                    font=self.FONTS["body_bold"],
                    fill=algo["color"],
                    anchor="s"
                )

                # 显示算法名称和图标
                self.comparison_canvas.create_text(
                    x + bar_width / 2, axis_y_end + 20,
                    text=f"{algo['icon']} {algo['abbr']}",
                    font=self.FONTS["body_bold"],
                    fill=self.COLORS["text_primary"],
                    anchor="n"
                )

                # 显示完整名称
                self.comparison_canvas.create_text(
                    x + bar_width / 2, axis_y_end + 40,
                    text=algo["name"],
                    font=self.FONTS["small"],
                    fill=self.COLORS["text_secondary"],
                    anchor="n"
                )

            # ========== 4. 效率提升标签（可选）==========
            if bf_count > 0 and (kmp_count < bf_count or opt_count < bf_count):
                self._draw_efficiency_labels(bf_count, kmp_count, opt_count, algorithms,
                                             start_x, bar_width, bar_spacing, axis_y_end)

            # ========== 5. 图例（右侧）==========
            self._draw_simple_legend(canvas_width, chart_y, algorithms)

            # 设置滚动区域
            self.comparison_canvas.config(
                scrollregion=(0, 0, canvas_width, chart_y + chart_height + 80)
            )

            print(f"对比图表绘制完成：暴力={bf_count}, KMP={kmp_count}, 生物={opt_count}")

        except Exception as e:
            print(f"绘制对比图表错误: {e}")
            import traceback
            traceback.print_exc()

