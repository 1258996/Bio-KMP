    def _last_all_steps(self):
        """所有算法跳转到最后一步"""
        # 停止所有动画
        self._pause_all_animations()

        # 暴力算法
        if hasattr(self, 'bf_steps') and self.bf_steps:
            self.bf_current_step = len(self.bf_steps) - 1
        else:
            self.bf_current_step = 0

        # KMP算法
        if hasattr(self, 'trad_steps') and self.trad_steps:
            self.trad_current_step = len(self.trad_steps) - 1
        else:
            self.trad_current_step = 0

        # 生物算法
        if hasattr(self, 'opt_steps') and self.opt_steps:
            self.opt_current_step = len(self.opt_steps) - 1
        else:
            self.opt_current_step = 0

        self._update_side_by_side_scenes()
        self.side_by_side_status.set("已跳转到最后步")
    def _reset_all_side_by_side(self):
        """重置并排动画视图"""
        # 停止所有动画
        self._pause_all_animations()

        # 重置步骤到初始状态
        self._first_all_steps()

        # 更新状态显示
        self.side_by_side_status.set("已重置")
    def _play_all_animations_sync(self):
        """同步播放所有算法动画"""
        self._pause_all_animations()

        # 重置所有动画到第一步
        self._first_all_steps()

        def animate_all():
            if self._next_all_steps():
                self.root.after(500, animate_all)  # 每500ms播放一步

        self.side_by_side_animation_id = self.root.after(100, animate_all)
        self.side_by_side_status.set("正在同步播放...")

    def _pause_all_animations(self):
        """暂停所有动画"""
        if hasattr(self, 'side_by_side_animation_id') and self.side_by_side_animation_id:
            self.root.after_cancel(self.side_by_side_animation_id)
            self.side_by_side_animation_id = None
        self.side_by_side_status.set("已暂停")

    def _first_all_steps(self):
        """所有算法跳转到第一步"""
        self.bf_current_step = 0
        self.trad_current_step = 0
        self.opt_current_step = 0

        self._draw_side_by_side_bf_scene(0)
        self._draw_side_by_side_kmp_scene(0)
        self._draw_side_by_side_opt_scene(0)

    def _prev_all_steps(self):
        """所有算法上一步"""
        if self.bf_current_step > 0:
            self.bf_current_step -= 1
        if self.trad_current_step > 0:
            self.trad_current_step -= 1
        if self.opt_current_step > 0:
            self.opt_current_step -= 1

        self._update_side_by_side_scenes()

    def _next_all_steps(self):
        """所有算法下一步"""
        bf_has_next = False
        kmp_has_next = False
        opt_has_next = False

        # 检查暴力算法
        if hasattr(self, 'bf_steps') and self.bf_steps:
            bf_has_next = self.bf_current_step < len(self.bf_steps) - 1
        # 检查KMP算法
        if hasattr(self, 'trad_steps') and self.trad_steps:
            kmp_has_next = self.trad_current_step < len(self.trad_steps) - 1
        # 检查生物算法
        if hasattr(self, 'opt_steps') and self.opt_steps:
            opt_has_next = self.opt_current_step < len(self.opt_steps) - 1

        if bf_has_next:
            self.bf_current_step += 1
        if kmp_has_next:
            self.trad_current_step += 1
        if opt_has_next:
            self.opt_current_step += 1

        self._update_side_by_side_scenes()

        return bf_has_next or kmp_has_next or opt_has_next

    def _update_side_by_side_scenes(self):
        """更新所有并排场景"""
        self._draw_side_by_side_bf_scene(self.bf_current_step)
        self._draw_side_by_side_kmp_scene(self.trad_current_step)
        self._draw_side_by_side_opt_scene(self.opt_current_step)

        # 更新状态
        total_bf = len(self.bf_steps) if self.bf_steps else 0
        total_kmp = len(self.trad_steps) if self.trad_steps else 0
        total_opt = len(self.opt_steps) if self.opt_steps else 0

