        # 生成富含CpG的序列
        for _ in range(cpg_length):
            if random.random() < 0.3:  # 30%概率生成CG二联体
                cpg_island += "CG"
            else:
                cpg_island += random.choice('GC')

        # 添加上下游低CpG区域
        upstream = ''.join(random.choices('AT', weights=[0.5, 0.5], k=random.randint(20, 30)))
        downstream = ''.join(random.choices('ATCG', k=random.randint(20, 30)))

        full_sequence = upstream + cpg_island + downstream

        # 设置DNA序列
        self.dna_entry.delete(0, tk.END)
        self.dna_entry.insert(0, full_sequence)

        # 自动设置模式串
        self.pattern_entry.delete(0, tk.END)
        self.pattern_entry.insert(0, "CG")

