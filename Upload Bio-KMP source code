    def _validate_algorithm_results(self):
        """验证算法结果"""
        try:
            # 检查是否有数据
            if not hasattr(self, 'text') or not self.text:
                messagebox.showinfo("提示", "请先在'基因序列分析'页面生成数据！")
                return

            # 收集各算法的匹配结果
            bf_matches = self._get_bf_match_positions()
            kmp_matches = self._get_kmp_match_positions()
            opt_matches = self._get_opt_match_positions()

            # 收集比较次数
            bf_comparisons = self._get_bf_comparison_count()
            kmp_comparisons = self._get_kmp_comparison_count()
            opt_comparisons = self._get_opt_comparison_count()

            # 生成验证报告
            report = self._generate_validation_report(bf_matches, kmp_matches, opt_matches,
                                                      bf_comparisons, kmp_comparisons, opt_comparisons)

            # 更新显示
            self.validation_result_text.config(state='normal')
            self.validation_result_text.delete(1.0, tk.END)
            self.validation_result_text.insert(1.0, report)
            self.validation_result_text.config(state='disabled')

            # 显示验证结果对话框
            messagebox.showinfo("验证完成", "算法结果验证已完成！\n\n详细结果已在验证页面显示。")

        except Exception as e:
            messagebox.showerror("验证错误", f"验证过程中发生错误：\n{str(e)}")

    def _get_bf_match_positions(self):
        """获取暴力算法的匹配位置"""
        matches = []
        if hasattr(self, 'bf_steps') and self.bf_steps:
            for step in self.bf_steps:
                if step.get('type') == 'found':
                    match_pos = step.get('start_i', 0)
                    if 0 <= match_pos < len(self.text):
                        matches.append(match_pos)
        return list(set(matches))

    def _get_kmp_match_positions(self):
        """获取KMP算法的匹配位置"""
        matches = []
        if hasattr(self, 'trad_steps') and self.trad_steps:
            for step in self.trad_steps:
                if step.get('type') == 'found':
                    match_pos = step.get('i', 0) - len(self.pattern)
                    if 0 <= match_pos < len(self.text):
                        matches.append(match_pos)
        return list(set(matches))

    def _get_opt_match_positions(self):
        """获取生物算法的匹配位置"""
        matches = []
        if hasattr(self, 'opt_steps') and self.opt_steps:
            for step in self.opt_steps:
                if step.get('type') == 'found':
                    match_pos = step.get('i', 0) - len(self.pattern)
                    if 0 <= match_pos < len(self.text):
                        matches.append(match_pos)
        return list(set(matches))

    def _get_bf_comparison_count(self):
        """获取暴力算法的比较次数"""
        if hasattr(self, 'bf_steps') and self.bf_steps:
            last_step = self.bf_steps[-1]
            return last_step.get('comparison_count', 0)
        return 0

    def _get_kmp_comparison_count(self):
        """获取KMP算法的比较次数"""
        comparison_count = 0
        if hasattr(self, 'trad_steps') and self.trad_steps:
            for step in self.trad_steps:
                if step.get('type') in ['match', 'mismatch']:
                    comparison_count += 1
        return comparison_count

    def _get_opt_comparison_count(self):
        """获取生物算法的比较次数"""
        comparison_count = 0
        if hasattr(self, 'opt_steps') and self.opt_steps:
            for step in self.opt_steps:
                if step.get('type') in ['match', 'mismatch']:
                    comparison_count += 1
        return comparison_count

    def _generate_validation_report(self, bf_matches, kmp_matches, opt_matches,
                                    bf_comparisons, kmp_comparisons, opt_comparisons):
        """生成验证报告"""
        n = len(self.text)
        m = len(self.pattern)

        report = "=" * 60 + "\n"
        report += "🔬 算法结果验证报告\n"
        report += "=" * 60 + "\n\n"

        # 1. 基本数据信息
        report += "📊 数据概览\n"
        report += f"- 文本串长度: {n} 个字符\n"
        report += f"- 模式串长度: {m} 个字符\n"
        report += f"- 搜索模式: {self.pattern}\n\n"

        # 2. 匹配结果对比
        report += "🎯 匹配结果对比\n"
        report += f"- 暴力算法找到匹配: {len(bf_matches)} 个\n"
        report += f"- KMP算法找到匹配: {len(kmp_matches)} 个\n"
        report += f"- 生物算法找到匹配: {len(opt_matches)} 个\n\n"

        # 3. 匹配位置详细对比
        bf_matches_sorted = sorted(bf_matches)
        kmp_matches_sorted = sorted(kmp_matches)
        opt_matches_sorted = sorted(opt_matches)

        report += "📍 匹配位置对比\n"
        report += f"暴力算法: {bf_matches_sorted}\n"
        report += f"KMP算法: {kmp_matches_sorted}\n"
        report += f"生物算法: {opt_matches_sorted}\n\n"

        # 4. 结果一致性检查
        report += "✅ 结果一致性检查\n"

        all_same = (bf_matches_sorted == kmp_matches_sorted == opt_matches_sorted)

        if all_same:
            report += "🎉 所有算法结果完全一致！\n"
        else:
            report += "⚠️ 算法结果存在差异：\n"

            # 检查两两差异
            if bf_matches_sorted != kmp_matches_sorted:
                bf_only = set(bf_matches_sorted) - set(kmp_matches_sorted)
                kmp_only = set(kmp_matches_sorted) - set(bf_matches_sorted)
                if bf_only:
                    report += f"  - 暴力算法有而KMP算法无: {sorted(list(bf_only))}\n"
                if kmp_only:
                    report += f"  - KMP算法有而暴力算法无: {sorted(list(kmp_only))}\n"

            if kmp_matches_sorted != opt_matches_sorted:
                kmp_only = set(kmp_matches_sorted) - set(opt_matches_sorted)
                opt_only = set(opt_matches_sorted) - set(kmp_matches_sorted)
                if kmp_only:
                    report += f"  - KMP算法有而生物算法无: {sorted(list(kmp_only))}\n"
                if opt_only:
                    report += f"  - 生物算法有而KMP算法无: {sorted(list(opt_only))}\n"

        report += "\n"

        # 5. 性能对比
        report += "⚡ 性能对比（比较次数）\n"
        report += f"- 暴力算法: {bf_comparisons} 次比较\n"
        report += f"- KMP算法: {kmp_comparisons} 次比较\n"
        report += f"- 生物算法: {opt_comparisons} 次比较\n\n"

        # 6. 效率提升计算
        if bf_comparisons > 0:
            kmp_improvement = (bf_comparisons - kmp_comparisons) / bf_comparisons * 100
            opt_improvement = (bf_comparisons - opt_comparisons) / bf_comparisons * 100

            report += "📈 效率提升\n"
            report += f"- KMP相比暴力算法: {kmp_improvement:.1f}%\n"
            report += f"- 生物算法相比暴力算法: {opt_improvement:.1f}%\n\n"

        # 7. 算法建议
        report += "💡 算法选择建议\n"

        if all_same:
            report += "所有算法都找到正确的匹配位置，您可以根据以下因素选择：\n"
            if kmp_comparisons < bf_comparisons * 0.5:
                report += "✅ 推荐使用KMP算法（效率提升明显）\n"
            elif opt_comparisons < kmp_comparisons:
                report += "✅ 推荐使用生物算法（比KMP更高效）\n"
            else:
                report += "✅ 三种算法都可用，KMP通常是最佳平衡\n"
        else:
            report += "⚠️ 注意：算法结果存在差异\n"
            report += "建议检查算法实现或使用额外验证方法\n"

        report += "\n" + "=" * 60 + "\n"
        report += f"验证时间: {self._get_current_time()}\n"
        report += "=" * 60

        return report

