    def _get_enhanced_char_style(self, position, step, found_matches, exclusive_matches):
        """获取增强的字符样式"""
        style = {
            "fill": self.COLORS["primary_light"],
            "outline": self.COLORS["primary"],
            "text": self.COLORS["primary_dark"],
            "marks": []
        }

        # 检查是否在当前匹配中
        current_start = step['i'] - step['j']
        is_current_match_start = position == current_start
        is_in_current_match = current_start <= position < current_start + step['j']

        # 检查是否在已找到的匹配中
        is_in_found_match = position in found_matches

        # 检查是否是生物算法特有匹配
        is_exclusive_match = position in exclusive_matches

        # 检查队列状态
        memory_q = step.get('memory_queue', [])
        candidate_q = step.get('candidate_queue', [])
        is_in_memory_queue = position in memory_q
        is_in_candidate_queue = any(
            isinstance(cand, tuple) and cand[0] == position for cand in candidate_q
        )

        # 确定样式（优先级：特有匹配 > 已找到匹配 > 当前匹配 > 队列状态 > 普通）
        if is_exclusive_match:
            style["fill"] = self.COLORS["success"]
            style["outline"] = self.COLORS["success_dark"]
            style["text"] = self.COLORS["bg"]
            style["marks"].append("exclusive")

        elif is_in_found_match:
            style["fill"] = self.COLORS["success_light"]
            style["outline"] = self.COLORS["success"]
            style["text"] = self.COLORS["success_dark"]
            style["marks"].append("found")

        elif is_in_current_match:
            style["fill"] = self.COLORS["accent_light"]
            style["outline"] = self.COLORS["accent"]
            style["text"] = self.COLORS["accent_dark"]
            style["marks"].append("current_match")

        elif position == step['i']:
            style["fill"] = self.COLORS["primary"]
            style["outline"] = self.COLORS["primary_dark"]
            style["text"] = self.COLORS["bg"]
            style["marks"].append("current")

        elif is_current_match_start:
            style["fill"] = self.COLORS["warning_light"]
            style["outline"] = self.COLORS["warning"]
            style["text"] = self.COLORS["warning_dark"]
            style["marks"].append("start")

        elif is_in_candidate_queue:
            style["fill"] = self.COLORS["info_light"]
            style["outline"] = self.COLORS["info"]
            style["text"] = self.COLORS["info_dark"]
            style["marks"].append("candidate")

        elif is_in_memory_queue:
            style["fill"] = self.COLORS["warning_light"]
            style["outline"] = self.COLORS["warning"]
            style["text"] = self.COLORS["warning_dark"]
            style["marks"].append("memory")

        return style

